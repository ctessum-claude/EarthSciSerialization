{
  "esm": "0.1.0",
  "metadata": {
    "name": "NumericalEdgeCases",
    "description": "Test numerical edge cases including overflow, underflow, NaN, and Inf",
    "authors": ["Robustness Test"]
  },
  "models": {
    "NumericalModel": {
      "variables": {
        "overflow_test": { "type": "state", "units": "1", "default": 1.7976931348623157e+308 },
        "underflow_test": { "type": "state", "units": "1", "default": 5e-324 },
        "nan_test": { "type": "parameter", "units": "1", "default": "NaN" },
        "inf_test": { "type": "parameter", "units": "1", "default": "Infinity" },
        "neg_inf_test": { "type": "parameter", "units": "1", "default": "-Infinity" },
        "zero_div": { "type": "algebraic", "units": "1", "expression": { "op": "/", "args": [1, 0] } },
        "sqrt_negative": { "type": "algebraic", "units": "1", "expression": { "op": "sqrt", "args": [-1] } },
        "log_zero": { "type": "algebraic", "units": "1", "expression": { "op": "log", "args": [0] } },
        "pow_overflow": { "type": "algebraic", "units": "1", "expression": { "op": "pow", "args": [10, 1000] } }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["overflow_test"], "wrt": "t" },
          "rhs": { "op": "*", "args": ["overflow_test", "overflow_test"] }
        },
        {
          "lhs": { "op": "D", "args": ["underflow_test"], "wrt": "t" },
          "rhs": { "op": "/", "args": ["underflow_test", 1e100] }
        }
      ]
    }
  }
}