{
  "esm": "0.1.0",
  "metadata": {
    "name": "CompleteCouplingTests",
    "description": "Test all 6 coupling types: operator_compose, couple2, variable_map, operator_apply, callback, event",
    "authors": ["ESM Test Suite"],
    "created": "2026-02-14T00:00:00Z",
    "tags": ["coupling", "comprehensive", "all-types"]
  },

  "models": {
    "AtmosphericChemistry": {
      "coupletype": "ChemistryCoupler",
      "reference": {
        "notes": "Primary atmospheric chemistry system for coupling tests"
      },
      "variables": {
        "O3": {
          "type": "state",
          "units": "mol/mol",
          "default": 40e-9,
          "description": "Ozone mixing ratio"
        },
        "NO": {
          "type": "state",
          "units": "mol/mol",
          "default": 0.1e-9,
          "description": "Nitric oxide mixing ratio"
        },
        "NO2": {
          "type": "state",
          "units": "mol/mol",
          "default": 1e-9,
          "description": "Nitrogen dioxide mixing ratio"
        },
        "temperature": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Air temperature"
        },
        "pressure": {
          "type": "parameter",
          "units": "Pa",
          "default": 101325.0,
          "description": "Air pressure"
        },
        "k_NO_O3": {
          "type": "parameter",
          "units": "cm^3/molec/s",
          "default": 1.8e-12,
          "description": "Rate constant for NO + O3 → NO2"
        },
        "jNO2": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.005,
          "description": "NO2 photolysis rate"
        }
      },
      "equations": [
        {
          "lhs": {"op": "D", "args": ["O3"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {"op": "*", "args": [{"op": "-", "args": ["k_NO_O3"]}, "O3", "NO"]},
              {"op": "*", "args": ["jNO2", "NO2"]}
            ]
          }
        },
        {
          "lhs": {"op": "D", "args": ["NO"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {"op": "*", "args": [{"op": "-", "args": ["k_NO_O3"]}, "O3", "NO"]},
              {"op": "*", "args": ["jNO2", "NO2"]}
            ]
          }
        },
        {
          "lhs": {"op": "D", "args": ["NO2"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {"op": "*", "args": ["k_NO_O3", "O3", "NO"]},
              {"op": "*", "args": [{"op": "-", "args": ["jNO2"]}, "NO2"]}
            ]
          }
        }
      ]
    },

    "AdvectionTransport": {
      "reference": {
        "notes": "Transport operator using _var placeholder for operator_compose coupling"
      },
      "variables": {
        "u_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 10.0,
          "description": "Eastward wind component"
        },
        "v_wind": {
          "type": "parameter",
          "units": "m/s",
          "default": 5.0,
          "description": "Northward wind component"
        }
      },
      "equations": [
        {
          "_comment": "Generic advection equation applied to all state variables",
          "lhs": {"op": "D", "args": ["_var"], "wrt": "t"},
          "rhs": {
            "op": "+",
            "args": [
              {"op": "*", "args": [{"op": "-", "args": ["u_wind"]}, {"op": "grad", "args": ["_var"], "dim": "x"}]},
              {"op": "*", "args": [{"op": "-", "args": ["v_wind"]}, {"op": "grad", "args": ["_var"], "dim": "y"}]}
            ]
          }
        }
      ]
    },

    "SurfaceExchange": {
      "coupletype": "SurfaceExchangeCoupler",
      "reference": {
        "notes": "Surface deposition model for couple2 coupling"
      },
      "variables": {
        "surface_resistance": {
          "type": "parameter",
          "units": "s/m",
          "default": 100.0,
          "description": "Surface resistance to deposition"
        },
        "aerodynamic_resistance": {
          "type": "parameter",
          "units": "s/m",
          "default": 50.0,
          "description": "Aerodynamic resistance"
        },
        "deposition_velocity_O3": {
          "type": "observed",
          "units": "m/s",
          "expression": {
            "op": "/",
            "args": [
              1.0,
              {"op": "+", "args": ["surface_resistance", "aerodynamic_resistance"]}
            ]
          },
          "description": "O3 deposition velocity"
        },
        "boundary_layer_height": {
          "type": "parameter",
          "units": "m",
          "default": 1000.0,
          "description": "Planetary boundary layer height"
        }
      },
      "equations": []
    },

    "EmissionSources": {
      "reference": {
        "notes": "Emission model for testing callback coupling"
      },
      "variables": {
        "NOx_emission_rate": {
          "type": "parameter",
          "units": "mol/mol/s",
          "default": 1e-11,
          "description": "NOx emission rate"
        },
        "diurnal_factor": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Diurnal emission scaling factor"
        },
        "weekday_factor": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 1.0,
          "description": "Weekday/weekend scaling factor"
        }
      },
      "equations": [
        {
          "_comment": "NO emission with time-varying factors",
          "lhs": {"op": "D", "args": ["NO"], "wrt": "t"},
          "rhs": {
            "op": "*",
            "args": ["NOx_emission_rate", "diurnal_factor", "weekday_factor"]
          }
        }
      ],
      "discrete_events": [
        {
          "name": "hourly_emission_update",
          "trigger": {
            "type": "periodic",
            "interval": 3600.0
          },
          "affects": [
            {
              "lhs": "diurnal_factor",
              "rhs": {
                "op": "+",
                "args": [
                  1.0,
                  {"op": "*", "args": [0.5, {"op": "sin", "args": [{"op": "/", "args": [{"op": "*", "args": [2, 3.14159, "t"]}, 86400]}]}]}
                ]
              }
            }
          ],
          "discrete_parameters": ["diurnal_factor"],
          "description": "Update diurnal emission pattern every hour"
        }
      ]
    }
  },

  "data_loaders": {
    "MeteorologicalData": {
      "type": "gridded_data",
      "loader_id": "GEOS_FP",
      "config": {
        "resolution": "0.5x0.625_global",
        "variables": ["temperature", "pressure", "u_wind", "v_wind"],
        "update_frequency": "3h"
      },
      "reference": {
        "citation": "NASA GEOS Forward Processing meteorological data"
      },
      "provides": {
        "temperature": {"units": "K", "description": "Air temperature"},
        "pressure": {"units": "Pa", "description": "Surface pressure"},
        "u_wind": {"units": "m/s", "description": "Eastward wind"},
        "v_wind": {"units": "m/s", "description": "Northward wind"}
      },
      "temporal_resolution": "PT3H",
      "spatial_resolution": {"lon": 0.625, "lat": 0.5}
    },

    "EmissionInventory": {
      "type": "emissions",
      "loader_id": "EDGAR_v6",
      "config": {
        "year": 2018,
        "sectors": ["transport", "industry", "residential"]
      },
      "provides": {
        "NOx_emission_rate": {"units": "mol/mol/s", "description": "Nitrogen oxides emission rate"}
      }
    }
  },

  "operators": {
    "DryDeposition": {
      "operator_id": "ResistanceBasedDeposition",
      "reference": {
        "doi": "10.1016/0004-6981(89)90153-4",
        "citation": "Wesely, 1989. Parameterization of surface resistances"
      },
      "config": {
        "method": "resistance_model",
        "species": ["O3", "NO2"],
        "land_use_categories": 11
      },
      "needed_vars": ["O3", "NO2", "temperature", "surface_resistance"],
      "modifies": ["O3", "NO2"],
      "description": "Resistance-based dry deposition for reactive gases"
    },

    "TurbulentMixing": {
      "operator_id": "KProfile_PBL",
      "reference": {
        "notes": "K-profile turbulent mixing in planetary boundary layer"
      },
      "config": {
        "mixing_scheme": "k_profile",
        "richardson_critical": 0.25
      },
      "needed_vars": ["boundary_layer_height", "u_wind", "v_wind"],
      "modifies": ["O3", "NO", "NO2"],
      "description": "Vertical turbulent mixing using K-profile method"
    }
  },

  "coupling": [
    {
      "_comment": "Type 1: operator_compose - Add transport to chemistry",
      "type": "operator_compose",
      "systems": ["AtmosphericChemistry", "AdvectionTransport"],
      "description": "Add horizontal advection to all chemical species"
    },

    {
      "_comment": "Type 2: couple2 - Bidirectional coupling via connector equations",
      "type": "couple2",
      "systems": ["AtmosphericChemistry", "SurfaceExchange"],
      "coupletype_pair": ["ChemistryCoupler", "SurfaceExchangeCoupler"],
      "connector": {
        "equations": [
          {
            "from": "SurfaceExchange.deposition_velocity_O3",
            "to": "AtmosphericChemistry.O3",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                {"op": "-", "args": ["SurfaceExchange.deposition_velocity_O3"]},
                "AtmosphericChemistry.O3",
                {"op": "/", "args": [1.0, "SurfaceExchange.boundary_layer_height"]}
              ]
            }
          }
        ]
      },
      "description": "Couple surface deposition to atmospheric chemistry"
    },

    {
      "_comment": "Type 3: variable_map - Replace parameters with data loader variables",
      "type": "variable_map",
      "from": "MeteorologicalData.temperature",
      "to": "AtmosphericChemistry.temperature",
      "transform": "param_to_var",
      "description": "Use meteorological temperature instead of constant"
    },

    {
      "type": "variable_map",
      "from": "MeteorologicalData.pressure",
      "to": "AtmosphericChemistry.pressure",
      "transform": "param_to_var",
      "description": "Use meteorological pressure"
    },

    {
      "type": "variable_map",
      "from": "MeteorologicalData.u_wind",
      "to": "AdvectionTransport.u_wind",
      "transform": "param_to_var",
      "description": "Use meteorological eastward wind"
    },

    {
      "type": "variable_map",
      "from": "MeteorologicalData.v_wind",
      "to": "AdvectionTransport.v_wind",
      "transform": "param_to_var",
      "description": "Use meteorological northward wind"
    },

    {
      "type": "variable_map",
      "from": "EmissionInventory.NOx_emission_rate",
      "to": "EmissionSources.NOx_emission_rate",
      "transform": "param_to_var",
      "description": "Use inventory emission rates"
    },

    {
      "_comment": "Type 4: operator_apply - Apply runtime operators during simulation",
      "type": "operator_apply",
      "operator": "DryDeposition",
      "description": "Apply dry deposition operator to surface grid cells"
    },

    {
      "type": "operator_apply",
      "operator": "TurbulentMixing",
      "description": "Apply vertical mixing operator in boundary layer"
    },

    {
      "_comment": "Type 5: callback - Register simulation callbacks",
      "type": "callback",
      "callback_id": "DiurnalEmissionScaling",
      "config": {
        "update_frequency": 3600.0,
        "local_solar_time": true,
        "timezone": "UTC"
      },
      "description": "Scale emissions based on local solar time"
    },

    {
      "type": "callback",
      "callback_id": "PhotolysisRateUpdate",
      "config": {
        "solar_zenith_angle": true,
        "cloud_optical_depth": true,
        "update_frequency": 600.0
      },
      "description": "Update photolysis rates based on solar conditions"
    },

    {
      "_comment": "Type 6: event - Cross-system events",
      "type": "event",
      "event_type": "continuous",
      "name": "ozone_threshold_emission_cutoff",
      "conditions": [
        {"op": "-", "args": ["AtmosphericChemistry.O3", 80e-9]}
      ],
      "affects": [
        {
          "lhs": "EmissionSources.NOx_emission_rate",
          "rhs": {"op": "*", "args": [{"op": "Pre", "args": ["EmissionSources.NOx_emission_rate"]}, 0.5]}
        }
      ],
      "description": "Reduce NOx emissions when ozone exceeds 80 ppb"
    },

    {
      "type": "event",
      "event_type": "discrete",
      "name": "weekend_emission_reduction",
      "trigger": {
        "type": "condition",
        "expression": {
          "op": ">=",
          "args": [
            {"op": "%", "args": [{"op": "floor", "args": [{"op": "/", "args": ["t", 86400]}]}, 7]},
            5
          ]
        }
      },
      "affects": [
        {
          "lhs": "EmissionSources.weekday_factor",
          "rhs": 0.7
        }
      ],
      "discrete_parameters": ["EmissionSources.weekday_factor"],
      "description": "Reduce emissions on weekends (days 5-6 of week)"
    }
  ],

  "domain": {
    "independent_variable": "t",
    "temporal": {
      "start": "2024-07-01T00:00:00Z",
      "end": "2024-07-08T00:00:00Z",
      "reference_time": "2024-07-01T00:00:00Z"
    },
    "spatial": {
      "x": {
        "min": 0.0,
        "max": 100000.0,
        "units": "meters",
        "grid_spacing": 5000.0
      },
      "y": {
        "min": 0.0,
        "max": 100000.0,
        "units": "meters",
        "grid_spacing": 5000.0
      }
    },
    "initial_conditions": {
      "type": "constant",
      "value": 0.0
    },
    "boundary_conditions": [
      {
        "type": "zero_gradient",
        "dimensions": ["x", "y"]
      }
    ],
    "element_type": "Float64"
  },

  "solver": {
    "strategy": "strang_threads",
    "config": {
      "threads": 4,
      "stiff_algorithm": "Rosenbrock23",
      "timestep": 300.0,
      "stiff_kwargs": {
        "abstol": 1e-8,
        "reltol": 1e-6
      }
    }
  }
}