[
  {
    "description": "Add coupling entry to existing file",
    "operation": "add_coupling",
    "input_file": {
      "esm": "0.1.0",
      "reaction_systems": {
        "Chemistry": {
          "species": {
            "O3": { "units": "mol/mol", "default": 40e-9, "description": "Ozone" },
            "NO": { "units": "mol/mol", "default": 0.1e-9, "description": "Nitric oxide" }
          },
          "parameters": {
            "T": { "units": "K", "default": 298.15, "description": "Temperature" }
          },
          "reactions": [
            {
              "id": "R1",
              "name": "NO_O3",
              "substrates": [{ "species": "NO", "stoichiometry": 1 }, { "species": "O3", "stoichiometry": 1 }],
              "products": [{ "species": "NO2", "stoichiometry": 1 }],
              "rate": 1.8e-12
            }
          ]
        }
      },
      "models": {
        "Transport": {
          "variables": {
            "u_wind": { "type": "parameter", "units": "m/s", "default": 5.0 },
            "v_wind": { "type": "parameter", "units": "m/s", "default": 2.0 }
          },
          "equations": [
            { "lhs": { "op": "D", "args": ["_var"], "wrt": "t" }, "rhs": { "op": "*", "args": ["u_wind", { "op": "grad", "args": ["_var"], "dim": "x" }] } }
          ]
        }
      },
      "data_loaders": {
        "MetData": {
          "type": "gridded_data",
          "loader_id": "GEOSFP",
          "config": { "resolution": "0.25x0.3125" },
          "provides": {
            "T": { "units": "K", "description": "Temperature" },
            "u": { "units": "m/s", "description": "Eastward wind" }
          }
        }
      },
      "coupling": [
        { "type": "operator_compose", "systems": ["Chemistry", "Transport"] }
      ]
    },
    "parameters": {
      "entry": { "type": "variable_map", "from": "MetData.T", "to": "Chemistry.T", "transform": "param_to_var" }
    },
    "expected_file": {
      "esm": "0.1.0",
      "reaction_systems": {
        "Chemistry": {
          "species": {
            "O3": { "units": "mol/mol", "default": 40e-9, "description": "Ozone" },
