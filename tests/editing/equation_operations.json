[
  {
    "description": "Add equation to existing model",
    "operation": "add_equation",
    "input_model": {
      "variables": {
        "x": { "type": "state", "units": "mol/mol", "default": 1e-9, "description": "First variable" },
        "y": { "type": "state", "units": "mol/mol", "default": 2e-9, "description": "Second variable" },
        "k1": { "type": "parameter", "units": "1/s", "default": 0.05, "description": "Rate constant 1" },
        "k2": { "type": "parameter", "units": "1/s", "default": 0.02, "description": "Rate constant 2" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": ["x"], "wrt": "t" }, "rhs": { "op": "*", "args": ["k1", "x"] } }
      ]
    },
    "parameters": {
      "equation": { "lhs": { "op": "D", "args": ["y"], "wrt": "t" }, "rhs": { "op": "*", "args": ["k2", "y"] } }
    },
    "expected_model": {
      "variables": {
        "x": { "type": "state", "units": "mol/mol", "default": 1e-9, "description": "First variable" },
        "y": { "type": "state", "units": "mol/mol", "default": 2e-9, "description": "Second variable" },
        "k1": { "type": "parameter", "units": "1/s", "default": 0.05, "description": "Rate constant 1" },
        "k2": { "type": "parameter", "units": "1/s", "default": 0.02, "description": "Rate constant 2" }
      },
      "equations": [
        { "lhs": { "op": "D", "args": ["x"], "wrt": "t" }, "rhs": { "op": "*", "args": ["k1", "x"] } },
        { "lhs": { "op": "D", "args": ["y"], "wrt": "t" }, "rhs": { "op": "*", "args": ["k2", "y"] } }
      ]
    },
    "expected_warnings": []
  },
