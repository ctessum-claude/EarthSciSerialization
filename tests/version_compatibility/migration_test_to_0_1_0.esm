{
  "esm": "0.1.0",
  "metadata": {
    "name": "MigrationTest_0_1_0",
    "description": "Same content as migration_test_from_0_0_5.esm but migrated to current format conventions",
    "authors": ["ESM Format Team"],
    "created": "2023-10-01T00:00:00Z",
    "migration_notes": "Migrated from version 0.0.5 - converted ppbv to mol/mol units"
  },
  "reaction_systems": {
    "LegacyChemistry": {
      "species": {
        "CH4": { "units": "mol/mol", "default": 1.9e-6, "description": "Methane in molar mixing ratio (migrated from ppbv)" },
        "OH": { "units": "molec/cm^3", "default": 2e6, "description": "Hydroxyl radical" },
        "H2O": { "units": "mol/mol", "default": 0.01, "description": "Water vapor (product)" }
      },
      "parameters": {
        "k_CH4_OH": { "units": "cm^3/molec/s", "default": 6.4e-15, "description": "CH4 + OH rate constant" }
      },
      "reactions": [
        {
          "id": "CH4_oxidation",
          "substrates": [
            { "species": "CH4", "stoichiometry": 1 },
            { "species": "OH", "stoichiometry": 1 }
          ],
          "products": [
            { "species": "H2O", "stoichiometry": 1 }
          ],
          "rate": { "op": "*", "args": ["k_CH4_OH", "CH4", "OH"] }
        }
      ]
    }
  }
}