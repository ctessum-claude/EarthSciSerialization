{
  "description": "Expression graph for a complex rate expression: 1.8e-12 * exp(-1370/T) * M",
  "input_file": "minimal_chemistry.esm",
  "input_selector": {
    "type": "expression",
    "system": "SimpleOzone",
    "reaction_id": "R1",
    "expression": { "op": "*", "args": [1.8e-12, { "op": "exp", "args": [{ "op": "/", "args": [-1370, "T"] }] }, "M"] }
  },
  "expected_nodes": [
    {
      "name": "T",
      "kind": "parameter",
      "units": "K",
      "system": "SimpleOzone"
    },
    {
      "name": "M",
      "kind": "parameter",
      "units": "molec/cm^3",
      "system": "SimpleOzone"
    }
  ],
  "expected_edges": [
    {
      "source": "T",
      "target": "expression_result",
      "relationship": "multiplicative",
      "equation_index": null,
      "expression": { "op": "exp", "args": [{ "op": "/", "args": [-1370, "T"] }] },
      "label": "T in exp(-1370/T)"
    },
    {
      "source": "M",
      "target": "expression_result",
      "relationship": "multiplicative",
      "equation_index": null,
      "expression": "M",
      "label": "M as multiplicative factor"
    }
  ],
  "export_formats": {
    "dot": "digraph {\n  \"T\" -> \"expression_result\" [label=\"multiplicative (exp(-1370/T))\"]\n  \"M\" -> \"expression_result\" [label=\"multiplicative\"]\n}",
    "mermaid": "graph TD\n  T --> expression_result\n  M --> expression_result",
    "json_adjacency": {
      "nodes": ["T", "M", "expression_result"],
      "adjacency": {
        "T": [
          {"neighbor": "expression_result", "edge": {"relationship": "multiplicative", "equation_index": null}}
        ],
        "M": [
          {"neighbor": "expression_result", "edge": {"relationship": "multiplicative", "equation_index": null}}
        ],
        "expression_result": []
      }
    }
  }
}