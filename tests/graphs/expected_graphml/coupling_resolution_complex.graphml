<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns
         http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">

  <!-- Key declarations for node attributes -->
  <key id="node_name" for="node" attr.name="name" attr.type="string"/>
  <key id="node_kind" for="node" attr.name="kind" attr.type="string"/>
  <key id="node_units" for="node" attr.name="units" attr.type="string"/>
  <key id="node_system" for="node" attr.name="system" attr.type="string"/>
  <key id="node_default" for="node" attr.name="default_value" attr.type="double"/>

  <!-- Key declarations for edge attributes -->
  <key id="edge_relationship" for="edge" attr.name="relationship" attr.type="string"/>
  <key id="edge_label" for="edge" attr.name="label" attr.type="string"/>
  <key id="edge_equation_index" for="edge" attr.name="equation_index" attr.type="int"/>
  <key id="edge_expression" for="edge" attr.name="expression" attr.type="string"/>
  <key id="edge_weight" for="edge" attr.name="weight" attr.type="double"/>

  <!-- Key declarations for graph attributes -->
  <key id="graph_title" for="graph" attr.name="title" attr.type="string"/>
  <key id="graph_description" for="graph" attr.name="description" attr.type="string"/>
  <key id="graph_version" for="graph" attr.name="esm_version" attr.type="string"/>

  <graph id="CoupledExpressionGraph" edgedefault="directed">
    <!-- Graph metadata -->
    <data key="graph_title">Complex Coupled System Test</data>
    <data key="graph_description">Tests coupling resolution across multiple systems with different relationship types</data>
    <data key="graph_version">0.1.0</data>

    <!-- Atmospheric Model Nodes -->
    <node id="atm_temperature">
      <data key="node_name">AtmosphericModel.temperature</data>
      <data key="node_kind">state</data>
      <data key="node_units">K</data>
      <data key="node_system">AtmosphericModel</data>
      <data key="node_default">288.15</data>
    </node>

    <node id="atm_pressure">
      <data key="node_name">AtmosphericModel.pressure</data>
      <data key="node_kind">state</data>
      <data key="node_units">Pa</data>
      <data key="node_system">AtmosphericModel</data>
      <data key="node_default">101325.0</data>
    </node>

    <node id="atm_wind_speed">
      <data key="node_name">AtmosphericModel.wind_speed</data>
      <data key="node_kind">state</data>
      <data key="node_units">m/s</data>
      <data key="node_system">AtmosphericModel</data>
      <data key="node_default">5.0</data>
    </node>

    <!-- Ocean Model Nodes -->
    <node id="ocn_sea_surface_temp">
      <data key="node_name">OceanModel.sea_surface_temp</data>
      <data key="node_kind">state</data>
      <data key="node_units">K</data>
      <data key="node_system">OceanModel</data>
      <data key="node_default">285.0</data>
    </node>

    <node id="ocn_salinity">
      <data key="node_name">OceanModel.salinity</data>
      <data key="node_kind">state</data>
      <data key="node_units">psu</data>
      <data key="node_system">OceanModel</data>
      <data key="node_default">35.0</data>
    </node>

    <node id="ocn_current_velocity">
      <data key="node_name">OceanModel.current_velocity</data>
      <data key="node_kind">state</data>
      <data key="node_units">m/s</data>
      <data key="node_system">OceanModel</data>
      <data key="node_default">0.2</data>
    </node>

    <!-- Land Model Nodes -->
    <node id="land_soil_temp">
      <data key="node_name">LandModel.soil_temp</data>
      <data key="node_kind">state</data>
      <data key="node_units">K</data>
      <data key="node_system">LandModel</data>
      <data key="node_default">283.0</data>
    </node>

    <node id="land_moisture">
      <data key="node_name">LandModel.moisture</data>
      <data key="node_kind">state</data>
      <data key="node_units">kg/m³</data>
      <data key="node_system">LandModel</data>
      <data key="node_default">0.3</data>
    </node>

    <!-- Chemistry Model Nodes -->
    <node id="chem_o3">
      <data key="node_name">ChemistryModel.O3</data>
      <data key="node_kind">species</data>
      <data key="node_units">ppb</data>
      <data key="node_system">ChemistryModel</data>
    </node>

    <node id="chem_no2">
      <data key="node_name">ChemistryModel.NO2</data>
      <data key="node_kind">species</data>
      <data key="node_units">ppb</data>
      <data key="node_system">ChemistryModel</data>
    </node>

    <node id="chem_co">
      <data key="node_name">ChemistryModel.CO</data>
      <data key="node_kind">species</data>
      <data key="node_units">ppb</data>
      <data key="node_system">ChemistryModel</data>
    </node>

    <node id="chem_k1">
      <data key="node_name">ChemistryModel.k1</data>
      <data key="node_kind">parameter</data>
      <data key="node_units">cm³/molecule/s</data>
      <data key="node_system">ChemistryModel</data>
      <data key="node_default">1.8e-12</data>
    </node>

    <node id="chem_k2">
      <data key="node_name">ChemistryModel.k2</data>
      <data key="node_kind">parameter</data>
      <data key="node_units">1/s</data>
      <data key="node_system">ChemistryModel</data>
      <data key="node_default">6.0e-3</data>
    </node>

    <!-- Data Loader Nodes -->
    <node id="met_solar_forcing">
      <data key="node_name">MeteorologicalData.solar_forcing</data>
      <data key="node_kind">observed</data>
      <data key="node_units">W/m²</data>
      <data key="node_system">MeteorologicalData</data>
    </node>

    <node id="met_wind_direction">
      <data key="node_name">MeteorologicalData.wind_direction</data>
      <data key="node_kind">observed</data>
      <data key="node_units">degrees</data>
      <data key="node_system">MeteorologicalData</data>
    </node>

    <!-- Operator Parameter Nodes -->
    <node id="turb_diffusion_coeff">
      <data key="node_name">TurbulentMixing.diffusion_coeff</data>
      <data key="node_kind">parameter</data>
      <data key="node_units">m²/s</data>
      <data key="node_system">TurbulentMixing</data>
      <data key="node_default">1e-5</data>
    </node>

    <node id="heat_exchange_coeff">
      <data key="node_name">HeatExchange.exchange_coeff</data>
      <data key="node_kind">parameter</data>
      <data key="node_units">W/m²/K</data>
      <data key="node_system">HeatExchange</data>
      <data key="node_default">20.0</data>
    </node>

    <!-- Variable mapping edges -->
    <edge id="e1" source="atm_temperature" target="ocn_sea_surface_temp">
      <data key="edge_relationship">variable_map</data>
      <data key="edge_label">Direct variable mapping</data>
      <data key="edge_weight">1.0</data>
    </edge>

    <edge id="e2" source="atm_temperature" target="chem_temperature">
      <data key="edge_relationship">variable_map</data>
      <data key="edge_label">Temperature coupling to chemistry</data>
      <data key="edge_weight">1.0</data>
    </edge>

    <edge id="e3" source="atm_pressure" target="chem_pressure">
      <data key="edge_relationship">variable_map</data>
      <data key="edge_label">Pressure coupling to chemistry</data>
      <data key="edge_weight">1.0</data>
    </edge>

    <!-- Operator composition edges -->
    <edge id="e4" source="ocn_sea_surface_temp" target="atm_temperature">
      <data key="edge_relationship">operator_compose</data>
      <data key="edge_label">Heat exchange feedback</data>
      <data key="edge_equation_index">0</data>
      <data key="edge_weight">0.8</data>
    </edge>

    <edge id="e5" source="met_solar_forcing" target="atm_temperature">
      <data key="edge_relationship">variable_map</data>
      <data key="edge_label">External forcing data</data>
      <data key="edge_weight">0.5</data>
    </edge>

    <edge id="e6" source="chem_o3" target="atm_temperature">
      <data key="edge_relationship">operator_compose</data>
      <data key="edge_label">Chemical mixing affects temperature</data>
      <data key="edge_weight">0.1</data>
    </edge>

    <!-- Rate parameter edges -->
    <edge id="e7" source="chem_k1" target="chem_no2">
      <data key="edge_relationship">rate</data>
      <data key="edge_label">Rate parameter influences NO2</data>
      <data key="edge_equation_index">0</data>
      <data key="edge_weight">1.0</data>
    </edge>

    <edge id="e8" source="chem_k1" target="chem_o3">
      <data key="edge_relationship">rate</data>
      <data key="edge_label">Rate parameter influences O3</data>
      <data key="edge_equation_index">0</data>
      <data key="edge_weight">1.0</data>
    </edge>

    <edge id="e9" source="chem_k2" target="chem_o3">
      <data key="edge_relationship">rate</data>
      <data key="edge_label">Temperature-dependent rate</data>
      <data key="edge_equation_index">1</data>
      <data key="edge_weight">1.0</data>
    </edge>

    <edge id="e10" source="chem_k2" target="chem_co">
      <data key="edge_relationship">rate</data>
      <data key="edge_label">Rate affects CO consumption</data>
      <data key="edge_equation_index">1</data>
      <data key="edge_weight">1.0</data>
    </edge>

    <!-- Temperature dependency edge -->
    <edge id="e11" source="atm_temperature" target="chem_k2">
      <data key="edge_relationship">multiplicative</data>
      <data key="edge_label">Temperature modulates reaction rate</data>
      <data key="edge_equation_index">1</data>
      <data key="edge_expression">exp(-1370/temperature)</data>
      <data key="edge_weight">0.7</data>
    </edge>

  </graph>
</graphml>