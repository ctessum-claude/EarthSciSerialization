digraph CoupledSystemExpressionGraph {
  rankdir=TB;
  compound=true;

  // Graph attributes
  graph [
    label="Complex Coupled System Expression Graph\nESM Version: 0.1.0"
    labelloc=t
    fontsize=16
    fontname="Arial Bold"
  ];

  // Node styling
  node [shape=ellipse, style=filled, fontname="Arial"];
  edge [fontname="Arial", fontsize=10];

  // Atmospheric Model subgraph
  subgraph cluster_atmosphere {
    label="Atmospheric Model";
    style=filled;
    color=lightblue;
    fontname="Arial Bold";

    "atm_temp" [label="temperature\n288.15 K", fillcolor=lightcyan, shape=ellipse];
    "atm_pressure" [label="pressure\n101325 Pa", fillcolor=lightcyan, shape=ellipse];
    "atm_wind" [label="wind_speed\n5.0 m/s", fillcolor=lightcyan, shape=ellipse];
  }

  // Ocean Model subgraph
  subgraph cluster_ocean {
    label="Ocean Model";
    style=filled;
    color=lightgreen;
    fontname="Arial Bold";

    "ocn_sst" [label="sea_surface_temp\n285.0 K", fillcolor=lightseagreen, shape=ellipse];
    "ocn_salinity" [label="salinity\n35.0 psu", fillcolor=lightseagreen, shape=ellipse];
    "ocn_current" [label="current_velocity\n0.2 m/s", fillcolor=lightseagreen, shape=ellipse];
  }

  // Land Model subgraph
  subgraph cluster_land {
    label="Land Model";
    style=filled;
    color=lightyellow;
    fontname="Arial Bold";

    "land_soil_temp" [label="soil_temp\n283.0 K", fillcolor=wheat, shape=ellipse];
    "land_moisture" [label="moisture\n0.3 kg/m³", fillcolor=wheat, shape=ellipse];
  }

  // Chemistry Model subgraph
  subgraph cluster_chemistry {
    label="Chemistry Model";
    style=filled;
    color=lavender;
    fontname="Arial Bold";

    "chem_o3" [label="O3\nppb", fillcolor=plum, shape=diamond];
    "chem_no2" [label="NO2\nppb", fillcolor=plum, shape=diamond];
    "chem_co" [label="CO\nppb", fillcolor=plum, shape=diamond];
    "chem_k1" [label="k1\n1.8e-12\ncm³/mol/s", fillcolor=orange, shape=box];
    "chem_k2" [label="k2\n6.0e-3 1/s", fillcolor=orange, shape=box];
  }

  // Data Loaders subgraph
  subgraph cluster_data {
    label="Meteorological Data";
    style=filled;
    color=lightgray;
    fontname="Arial Bold";

    "met_solar" [label="solar_forcing\nW/m²", fillcolor=gold, shape=house];
    "met_wind_dir" [label="wind_direction\ndegrees", fillcolor=gold, shape=house];
  }

  // Operators subgraph
  subgraph cluster_operators {
    label="Coupling Operators";
    style=filled;
    color=lightpink;
    fontname="Arial Bold";

    "turb_diff" [label="diffusion_coeff\n1e-5 m²/s", fillcolor=lightcoral, shape=hexagon];
    "heat_exch" [label="exchange_coeff\n20.0 W/m²/K", fillcolor=lightcoral, shape=hexagon];
  }

  // Variable mapping edges (blue, dashed)
  "atm_temp" -> "ocn_sst" [
    color=blue,
    style=dashed,
    label="variable_map",
    fontcolor=blue
  ];

  "atm_temp" -> "chem_temp" [
    color=blue,
    style=dashed,
    label="temp coupling",
    fontcolor=blue
  ];

  "atm_pressure" -> "chem_pressure" [
    color=blue,
    style=dashed,
    label="pressure coupling",
    fontcolor=blue
  ];

  // Operator composition edges (red, thick)
  "ocn_sst" -> "atm_temp" [
    color=red,
    style=bold,
    label="heat_exchange",
    fontcolor=red
  ];

  "met_solar" -> "atm_temp" [
    color=blue,
    style=dashed,
    label="forcing",
    fontcolor=blue
  ];

  "chem_o3" -> "atm_temp" [
    color=red,
    style=bold,
    label="mixing",
    fontcolor=red
  ];

  // Rate parameter dependencies (black, solid)
  "chem_k1" -> "chem_no2" [
    color=black,
    label="rate",
    arrowhead=normal
  ];

  "chem_k1" -> "chem_o3" [
    color=black,
    label="rate",
    arrowhead=normal
  ];

  "chem_k2" -> "chem_o3" [
    color=black,
    label="rate",
    arrowhead=normal
  ];

  "chem_k2" -> "chem_co" [
    color=black,
    label="rate",
    arrowhead=normal
  ];

  // Temperature dependency (green, curved)
  "atm_temp" -> "chem_k2" [
    color=darkgreen,
    style=dotted,
    label="exp(-1370/T)",
    fontcolor=darkgreen,
    constraint=false
  ];

  // Legend
  subgraph cluster_legend {
    label="Legend";
    style=filled;
    color=white;
    fontname="Arial Bold";
    rank=sink;

    "leg_var_map" [label="Variable Map", shape=plaintext];
    "leg_op_comp" [label="Operator Compose", shape=plaintext];
    "leg_rate" [label="Rate Dependency", shape=plaintext];
    "leg_mult" [label="Multiplicative", shape=plaintext];

    "leg_var_map" -> "leg_dummy1" [color=blue, style=dashed, label=""];
    "leg_op_comp" -> "leg_dummy2" [color=red, style=bold, label=""];
    "leg_rate" -> "leg_dummy3" [color=black, label=""];
    "leg_mult" -> "leg_dummy4" [color=darkgreen, style=dotted, label=""];

    "leg_dummy1" [style=invis];
    "leg_dummy2" [style=invis];
    "leg_dummy3" [style=invis];
    "leg_dummy4" [style=invis];
  }
}