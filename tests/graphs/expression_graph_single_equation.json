{
  "description": "Expression graph for a single equation: D(x)/dt = -x",
  "input_file": "metadata_minimal.esm",
  "input_selector": {
    "type": "equation",
    "model": "SimpleModel",
    "equation_index": 0
  },
  "expected_nodes": [
    {
      "name": "x",
      "kind": "state",
      "units": "dimensionless",
      "system": "SimpleModel"
    }
  ],
  "expected_edges": [
    {
      "source": "x",
      "target": "x",
      "relationship": "additive",
      "equation_index": 0,
      "expression": { "op": "-", "args": ["x"] }
    }
  ],
  "export_formats": {
    "dot": "digraph {\n  \"x\" -> \"x\" [label=\"D(x)/dt\"]\n}",
    "mermaid": "graph TD\n  x --> x",
    "json_adjacency": {
      "nodes": ["x"],
      "adjacency": {
        "x": [{"neighbor": "x", "edge": {"relationship": "additive", "equation_index": 0}}]
      }
    }
  }
}