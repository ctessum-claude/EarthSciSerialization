  },
  {
    "name": "hierarchical_subsystems",
    "description": "Nested subsystems with multi-level hierarchy and dependency resolution",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Hierarchical System Test",
        "description": "Tests nested subsystem structure and hierarchy resolution",
        "authors": ["Graph Test Suite"]
      },
      "models": {
        "GlobalModel": {
          "subsystems": {
            "RegionalModel_NA": {
              "subsystems": {
                "LocalModel_NYC": {
                  "variables": {"urban_temp": {"type": "state", "units": "K"}},
                  "equations": [{"lhs": "D(urban_temp)", "rhs": {"op": "+", "args": ["heating", "solar"]}}]
                },
                "LocalModel_LA": {
                  "variables": {"urban_temp": {"type": "state", "units": "K"}},
                  "equations": [{"lhs": "D(urban_temp)", "rhs": {"op": "+", "args": ["heating", "solar"]}}]
                }
              },
              "variables": {"regional_temp": {"type": "state", "units": "K"}},
              "equations": [{"lhs": "D(regional_temp)", "rhs": {"op": "mean", "args": ["LocalModel_NYC.urban_temp", "LocalModel_LA.urban_temp"]}}]
            },
            "RegionalModel_EU": {
              "variables": {"regional_temp": {"type": "state", "units": "K"}},
              "equations": [{"lhs": "D(regional_temp)", "rhs": {"op": "*", "args": ["heat_capacity", "temp_change"]}}]
            }
          },
          "variables": {"global_temp": {"type": "state", "units": "K"}},
          "equations": [{"lhs": "D(global_temp)", "rhs": {"op": "mean", "args": ["RegionalModel_NA.regional_temp", "RegionalModel_EU.regional_temp"]}}]
        }
      },
      "coupling": [
        {
          "source_model": "GlobalModel.RegionalModel_NA.LocalModel_NYC",
          "target_model": "GlobalModel.RegionalModel_NA",
          "coupling_type": "variable_map",
          "variable_map": {"urban_temp": "local_temp_NYC"}
        },
        {
          "source_model": "GlobalModel.RegionalModel_NA.LocalModel_LA",
          "target_model": "GlobalModel.RegionalModel_NA",
          "coupling_type": "variable_map",
          "variable_map": {"urban_temp": "local_temp_LA"}
        },
        {
          "source_model": "GlobalModel.RegionalModel_NA",
          "target_model": "GlobalModel",
          "coupling_type": "variable_map",
          "variable_map": {"regional_temp": "temp_NA"}
        },
        {
          "source_model": "GlobalModel.RegionalModel_EU",
          "target_model": "GlobalModel",
          "coupling_type": "variable_map",
          "variable_map": {"regional_temp": "temp_EU"}
        }
      ]
    },
    "expected_hierarchy": {
      "root": "GlobalModel",
      "levels": [
        {
          "level": 0,
          "systems": ["GlobalModel"],
          "parent": null
        },
        {
          "level": 1,
          "systems": ["GlobalModel.RegionalModel_NA", "GlobalModel.RegionalModel_EU"],
          "parent": "GlobalModel"
        },
        {
          "level": 2,
          "systems": ["GlobalModel.RegionalModel_NA.LocalModel_NYC", "GlobalModel.RegionalModel_NA.LocalModel_LA"],
          "parent": "GlobalModel.RegionalModel_NA"
        }
      ],
      "scoped_variables": [
        "GlobalModel.global_temp",
        "GlobalModel.RegionalModel_NA.regional_temp",
        "GlobalModel.RegionalModel_EU.regional_temp",
        "GlobalModel.RegionalModel_NA.LocalModel_NYC.urban_temp",
        "GlobalModel.RegionalModel_NA.LocalModel_LA.urban_temp"
      ]
    }
  },
  {
    "name": "cycle_detection_comprehensive",
    "description": "Multiple types of cycles including self-loops, simple cycles, and complex multi-node cycles",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Cycle Detection Test",
        "description": "Comprehensive cycle detection test cases",
        "authors": ["Graph Test Suite"]
      },
      "models": {
        "ModelA": {
          "variables": {"x": {"type": "state", "units": "dimensionless"}},
          "equations": [{"lhs": "D(x)", "rhs": {"op": "*", "args": ["-1", "x"]}}]
        },
        "ModelB": {
          "variables": {"y": {"type": "state", "units": "dimensionless"}},
          "equations": [{"lhs": "D(y)", "rhs": {"op": "+", "args": ["ModelC.z", "ModelA.x"]}}]
        },
        "ModelC": {
          "variables": {"z": {"type": "state", "units": "dimensionless"}},
          "equations": [{"lhs": "D(z)", "rhs": {"op": "*", "args": ["ModelB.y", "2.0"]}}]
        },
        "ModelD": {
          "variables": {"w": {"type": "state", "units": "dimensionless"}},
          "equations": [{"lhs": "D(w)", "rhs": {"op": "+", "args": ["ModelD.w", "external_forcing"]}}]
        }
      },
      "coupling": [
        {
          "source_model": "ModelA",
          "target_model": "ModelB",
          "coupling_type": "variable_map",
          "variable_map": {"x": "x_input"}
        },
        {
          "source_model": "ModelB",
          "target_model": "ModelC",
          "coupling_type": "variable_map",
          "variable_map": {"y": "y_input"}
        },
        {
          "source_model": "ModelC",
          "target_model": "ModelB",
          "coupling_type": "variable_map",
          "variable_map": {"z": "z_feedback"}
        }
      ]
    },
    "cycle_analysis": {
      "cycles_found": [
        {
          "type": "self_loop",
          "nodes": ["ModelD.w"],
          "description": "Model D has self-reference in its equation"
        },
        {
          "type": "simple_cycle",
          "nodes": ["ModelB.y", "ModelC.z"],
          "description": "Two-node cycle between Model B and Model C"
        },
        {
          "type": "indirect_cycle",
          "nodes": ["ModelB", "ModelC"],
          "description": "Component-level cycle through coupling"
        }
      ],
      "strongly_connected_components": [
        ["ModelA"],
        ["ModelB", "ModelC"],
        ["ModelD"]
      ],
      "topological_sort_possible": false,
      "execution_order_with_cycles": {
        "phases": [
          {
            "phase": 1,
            "components": ["ModelA"],
            "description": "Independent components first"
          },
          {
            "phase": 2,
            "components": ["ModelB", "ModelC"],
            "description": "Strongly connected component - requires iterative solution",
            "solution_method": "fixed_point_iteration"
          },
          {
            "phase": 3,
            "components": ["ModelD"],
            "description": "Self-referential component - requires implicit solver"
          }
        ]
      }
    }
  },
  {
    "name": "edge_relationship_types_comprehensive",
    "description": "Comprehensive coverage of all edge relationship types and their properties",
    "relationships": [
      {
        "type": "stoichiometric",
        "description": "Species production/consumption in chemical reactions",
        "properties": {"quantitative": true, "bidirectional": false, "mass_conserving": true},
        "example": {"source": "O2", "target": "H2O", "coefficient": 0.5, "reaction": "2H2 + O2 → 2H2O"}
      },
      {
        "type": "rate",
        "description": "Parameter influences on reaction rates",
        "properties": {"quantitative": true, "bidirectional": false, "temperature_dependent": true},
        "example": {"source": "k_photolysis", "target": "NO2", "expression": "k_photolysis * [NO2]"}
      },
      {
        "type": "additive",
        "description": "Variable appears additively in equation RHS",
        "properties": {"linear": true, "superposition": true},
        "example": {"source": "source_term", "target": "concentration", "expression": "d[C]/dt = source_term + other_terms"}
      },
      {
        "type": "multiplicative",
        "description": "Variable appears multiplicatively in equation RHS",
        "properties": {"nonlinear": true, "coupling_strength_varies": true},
        "example": {"source": "temperature", "target": "reaction_rate", "expression": "k * exp(-Ea/(R*T))"}
      },
      {
        "type": "variable_map",
        "description": "Direct variable coupling between systems",
        "properties": {"direct_coupling": true, "units_consistent": true, "instantaneous": true},
        "example": {"source": "atm_temp", "target": "ocean_boundary_temp", "mapping": "1:1"}
      },
      {
        "type": "operator_compose",
        "description": "Coupling through computational operators",
