[
  {
    "name": "coupling_resolution_complex",
    "description": "Complex multi-system coupling with various relationship types",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Complex Coupled System Test",
        "description": "Tests coupling resolution across multiple systems with different relationship types",
        "authors": ["Graph Test Suite"]
      },
      "models": {
        "AtmosphericModel": {
          "variables": {
            "temperature": {"type": "state", "units": "K", "default": 288.15},
            "pressure": {"type": "state", "units": "Pa", "default": 101325.0},
            "wind_speed": {"type": "state", "units": "m/s", "default": 5.0}
          },
          "equations": [
            {"lhs": "D(temperature)", "rhs": {"op": "-", "args": ["temperature", {"op": "/", "args": ["heat_flux", "heat_capacity"]}]}}
          ]
        },
        "OceanModel": {
          "variables": {
            "sea_surface_temp": {"type": "state", "units": "K", "default": 285.0},
            "salinity": {"type": "state", "units": "psu", "default": 35.0},
            "current_velocity": {"type": "state", "units": "m/s", "default": 0.2}
          },
          "equations": [
            {"lhs": "D(sea_surface_temp)", "rhs": {"op": "+", "args": ["heat_exchange", {"op": "*", "args": ["solar_forcing", "absorption_coeff"]}]}}
          ]
        },
        "LandModel": {
          "variables": {
            "soil_temp": {"type": "state", "units": "K", "default": 283.0},
            "moisture": {"type": "state", "units": "kg/m³", "default": 0.3}
          },
          "equations": [
            {"lhs": "D(soil_temp)", "rhs": {"op": "*", "args": ["thermal_conductivity", {"op": "grad", "args": ["soil_temp"]}]}}
          ]
        }
      },
      "reaction_systems": {
        "ChemistryModel": {
          "species": [
            {"name": "O3", "units": "ppb"},
            {"name": "NO2", "units": "ppb"},
            {"name": "CO", "units": "ppb"}
          ],
          "parameters": [
            {"name": "k1", "value": 1.8e-12, "units": "cm³/molecule/s"},
            {"name": "k2", "value": 6.0e-3, "units": "1/s"}
          ],
          "reactions": [
            {
              "substrates": {"NO2": 1},
              "products": {"NO": 1, "O3": 1},
              "rate_expression": "k1"
            },
            {
              "substrates": {"O3": 1, "CO": 1},
              "products": {"CO2": 1},
              "rate_expression": {"op": "*", "args": ["k2", {"op": "exp", "args": [{"op": "/", "args": ["-1370", "temperature"]}]}]}
            }
          ]
        }
      },
      "data_loaders": {
        "MeteorologicalData": {
          "type": "netcdf",
          "source": "met_forcing.nc",
          "variables": {
            "solar_forcing": {"units": "W/m²"},
            "wind_direction": {"units": "degrees"}
          }
        }
      },
      "operators": {
        "TurbulentMixing": {
          "type": "spatial",
          "parameters": {"diffusion_coeff": {"value": 1e-5, "units": "m²/s"}},
          "inputs": ["concentration"],
          "outputs": ["mixed_concentration"]
        },
        "HeatExchange": {
          "type": "coupling",
          "parameters": {"exchange_coeff": {"value": 20.0, "units": "W/m²/K"}},
          "inputs": ["temp_atmosphere", "temp_ocean"],
          "outputs": ["heat_flux"]
        }
      },
      "coupling": [
        {
          "source_model": "AtmosphericModel",
          "target_model": "OceanModel",
          "coupling_type": "variable_map",
          "variable_map": {"temperature": "sea_surface_temp"}
        },
        {
          "source_model": "AtmosphericModel",
          "target_model": "ChemistryModel",
          "coupling_type": "variable_map",
          "variable_map": {"temperature": "temperature", "pressure": "pressure"}
        },
        {
          "source_model": "OceanModel",
          "target_model": "AtmosphericModel",
          "coupling_type": "operator_compose",
          "operator": "HeatExchange",
          "connections": [
            {"from": "sea_surface_temp", "to": "temp_ocean"},
            {"from": "temperature", "to": "temp_atmosphere"}
          ]
        },
        {
          "source_model": "MeteorologicalData",
          "target_model": "AtmosphericModel",
          "coupling_type": "variable_map",
          "variable_map": {"solar_forcing": "solar_forcing"}
        },
        {
          "source_model": "ChemistryModel",
          "target_model": "AtmosphericModel",
          "coupling_type": "operator_compose",
          "operator": "TurbulentMixing",
          "connections": [
            {"from": "O3", "to": "concentration"}
          ]
        }
      ]
    },
    "expected_expression_graph": {
      "nodes": [
        {"name": "AtmosphericModel.temperature", "kind": "state", "units": "K", "system": "AtmosphericModel"},
        {"name": "AtmosphericModel.pressure", "kind": "state", "units": "Pa", "system": "AtmosphericModel"},
        {"name": "AtmosphericModel.wind_speed", "kind": "state", "units": "m/s", "system": "AtmosphericModel"},
        {"name": "OceanModel.sea_surface_temp", "kind": "state", "units": "K", "system": "OceanModel"},
        {"name": "OceanModel.salinity", "kind": "state", "units": "psu", "system": "OceanModel"},
        {"name": "OceanModel.current_velocity", "kind": "state", "units": "m/s", "system": "OceanModel"},
        {"name": "LandModel.soil_temp", "kind": "state", "units": "K", "system": "LandModel"},
        {"name": "LandModel.moisture", "kind": "state", "units": "kg/m³", "system": "LandModel"},
        {"name": "ChemistryModel.O3", "kind": "species", "units": "ppb", "system": "ChemistryModel"},
        {"name": "ChemistryModel.NO2", "kind": "species", "units": "ppb", "system": "ChemistryModel"},
        {"name": "ChemistryModel.CO", "kind": "species", "units": "ppb", "system": "ChemistryModel"},
        {"name": "ChemistryModel.k1", "kind": "parameter", "units": "cm³/molecule/s", "system": "ChemistryModel"},
        {"name": "ChemistryModel.k2", "kind": "parameter", "units": "1/s", "system": "ChemistryModel"},
        {"name": "MeteorologicalData.solar_forcing", "kind": "observed", "units": "W/m²", "system": "MeteorologicalData"},
        {"name": "MeteorologicalData.wind_direction", "kind": "observed", "units": "degrees", "system": "MeteorologicalData"},
        {"name": "TurbulentMixing.diffusion_coeff", "kind": "parameter", "units": "m²/s", "system": "TurbulentMixing"},
        {"name": "HeatExchange.exchange_coeff", "kind": "parameter", "units": "W/m²/K", "system": "HeatExchange"}
      ],
      "edges": [
        {"source": "AtmosphericModel.temperature", "target": "OceanModel.sea_surface_temp", "relationship": "variable_map", "equation_index": null, "label": "Direct variable mapping"},
        {"source": "AtmosphericModel.temperature", "target": "ChemistryModel.temperature", "relationship": "variable_map", "equation_index": null, "label": "Temperature coupling to chemistry"},
        {"source": "AtmosphericModel.pressure", "target": "ChemistryModel.pressure", "relationship": "variable_map", "equation_index": null, "label": "Pressure coupling to chemistry"},
        {"source": "OceanModel.sea_surface_temp", "target": "HeatExchange.temp_ocean", "relationship": "operator_compose", "equation_index": null, "label": "Ocean temperature to heat exchange operator"},
        {"source": "AtmosphericModel.temperature", "target": "HeatExchange.temp_atmosphere", "relationship": "operator_compose", "equation_index": null, "label": "Atmosphere temperature to heat exchange operator"},
        {"source": "HeatExchange.heat_flux", "target": "AtmosphericModel.temperature", "relationship": "operator_compose", "equation_index": 0, "label": "Heat flux affects atmospheric temperature"},
        {"source": "MeteorologicalData.solar_forcing", "target": "AtmosphericModel.solar_forcing", "relationship": "variable_map", "equation_index": null, "label": "External forcing data"},
        {"source": "ChemistryModel.O3", "target": "TurbulentMixing.concentration", "relationship": "operator_compose", "equation_index": null, "label": "Chemical species to mixing operator"},
        {"source": "TurbulentMixing.mixed_concentration", "target": "AtmosphericModel.O3_mixed", "relationship": "operator_compose", "equation_index": null, "label": "Mixed concentration to atmosphere"},
        {"source": "ChemistryModel.k1", "target": "ChemistryModel.NO2", "relationship": "rate", "equation_index": 0, "label": "Rate parameter influences NO2"},
        {"source": "ChemistryModel.k1", "target": "ChemistryModel.O3", "relationship": "rate", "equation_index": 0, "label": "Rate parameter influences O3"},
        {"source": "ChemistryModel.k2", "target": "ChemistryModel.O3", "relationship": "rate", "equation_index": 1, "label": "Temperature-dependent rate"},
        {"source": "ChemistryModel.k2", "target": "ChemistryModel.CO", "relationship": "rate", "equation_index": 1, "label": "Rate affects CO consumption"},
        {"source": "ChemistryModel.temperature", "target": "ChemistryModel.k2", "relationship": "multiplicative", "equation_index": 1, "expression": "exp(-1370/temperature)", "label": "Temperature modulates reaction rate"}
      ]
    },
    "expected_component_graph": {
      "nodes": [
        {"id": "AtmosphericModel", "name": "AtmosphericModel", "type": "model"},
        {"id": "OceanModel", "name": "OceanModel", "type": "model"},
        {"id": "LandModel", "name": "LandModel", "type": "model"},
        {"id": "ChemistryModel", "name": "ChemistryModel", "type": "reaction_system"},
        {"id": "MeteorologicalData", "name": "MeteorologicalData", "type": "data_loader"},
        {"id": "TurbulentMixing", "name": "TurbulentMixing", "type": "operator"},
        {"id": "HeatExchange", "name": "HeatExchange", "type": "operator"}
      ],
      "edges": [
        {"source": "AtmosphericModel", "target": "OceanModel", "coupling_type": "variable_map"},
        {"source": "AtmosphericModel", "target": "ChemistryModel", "coupling_type": "variable_map"},
        {"source": "OceanModel", "target": "AtmosphericModel", "coupling_type": "operator_compose"},
        {"source": "MeteorologicalData", "target": "AtmosphericModel", "coupling_type": "variable_map"},
        {"source": "ChemistryModel", "target": "AtmosphericModel", "coupling_type": "operator_compose"}
      ]
    },
    "expected_exports": {
      "dot": "digraph CoupledSystem {\n  rankdir=LR;\n  \n  subgraph cluster_atmosphere {\n    label=\"Atmospheric Model\";\n    style=filled;\n    color=lightblue;\n    \"AtmosphericModel.temperature\" [shape=ellipse, color=blue];\n    \"AtmosphericModel.pressure\" [shape=ellipse, color=blue];\n    \"AtmosphericModel.wind_speed\" [shape=ellipse, color=blue];\n  }\n  \n  subgraph cluster_ocean {\n    label=\"Ocean Model\";\n    style=filled;\n    color=lightgreen;\n    \"OceanModel.sea_surface_temp\" [shape=ellipse, color=green];\n    \"OceanModel.salinity\" [shape=ellipse, color=green];\n    \"OceanModel.current_velocity\" [shape=ellipse, color=green];\n  }\n  \n  subgraph cluster_chemistry {\n    label=\"Chemistry Model\";\n    style=filled;\n    color=lightyellow;\n    \"ChemistryModel.O3\" [shape=diamond, color=orange];\n    \"ChemistryModel.NO2\" [shape=diamond, color=orange];\n    \"ChemistryModel.CO\" [shape=diamond, color=orange];\n    \"ChemistryModel.k1\" [shape=box, color=red];\n    \"ChemistryModel.k2\" [shape=box, color=red];\n  }\n  \n  // Variable mapping edges (blue)\n  \"AtmosphericModel.temperature\" -> \"OceanModel.sea_surface_temp\" [color=blue, label=\"variable_map\"];\n  \"AtmosphericModel.temperature\" -> \"ChemistryModel.temperature\" [color=blue, label=\"variable_map\"];\n  \n  // Operator composition edges (red)\n  \"OceanModel.sea_surface_temp\" -> \"AtmosphericModel.temperature\" [color=red, label=\"operator_compose\"];\n  \"ChemistryModel.O3\" -> \"AtmosphericModel.O3_mixed\" [color=red, label=\"operator_compose\"];\n  \n  // Rate dependencies (black)\n  \"ChemistryModel.k1\" -> \"ChemistryModel.NO2\" [color=black, label=\"rate\"];\n  \"ChemistryModel.k2\" -> \"ChemistryModel.O3\" [color=black, label=\"rate\"];\n}",
      "mermaid": "graph TD\n  subgraph AtmModel[\"Atmospheric Model\"]\n    AT[\"temperature\"]\n    AP[\"pressure\"]\n    AW[\"wind_speed\"]\n  end\n  \n  subgraph OcnModel[\"Ocean Model\"]\n    OST[\"sea_surface_temp\"]\n    OS[\"salinity\"]\n    OCV[\"current_velocity\"]\n  end\n  \n  subgraph ChemModel[\"Chemistry Model\"]\n    CO3[\"O3\"]\n    CNO2[\"NO2\"]\n    CCO[\"CO\"]\n    CK1[\"k1\"]\n    CK2[\"k2\"]\n  end\n  \n  %% Variable mapping (dashed blue)\n  AT -.-> OST\n  AT -.-> ChemModel\n  \n  %% Operator composition (thick red)\n  OST ==> AT\n  CO3 ==> AtmModel\n  \n  %% Rate dependencies (solid black)\n  CK1 --> CNO2\n  CK2 --> CO3\n  \n  style AtmModel fill:#e1f5fe\n  style OcnModel fill:#e8f5e8\n  style ChemModel fill:#fff8e1",
      "graphml": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<graphml xmlns=\"http://graphml.graphdrawing.org/xmlns\">\n  <key id=\"node_name\" for=\"node\" attr.name=\"name\" attr.type=\"string\"/>\n  <key id=\"node_kind\" for=\"node\" attr.name=\"kind\" attr.type=\"string\"/>\n  <key id=\"node_units\" for=\"node\" attr.name=\"units\" attr.type=\"string\"/>\n  <key id=\"node_system\" for=\"node\" attr.name=\"system\" attr.type=\"string\"/>\n  <key id=\"edge_relationship\" for=\"edge\" attr.name=\"relationship\" attr.type=\"string\"/>\n  <key id=\"edge_label\" for=\"edge\" attr.name=\"label\" attr.type=\"string\"/>\n  \n  <graph id=\"CoupledExpressionGraph\" edgedefault=\"directed\">\n    <node id=\"n1\">\n      <data key=\"node_name\">AtmosphericModel.temperature</data>\n      <data key=\"node_kind\">state</data>\n      <data key=\"node_units\">K</data>\n      <data key=\"node_system\">AtmosphericModel</data>\n    </node>\n    <node id=\"n2\">\n      <data key=\"node_name\">OceanModel.sea_surface_temp</data>\n      <data key=\"node_kind\">state</data>\n      <data key=\"node_units\">K</data>\n      <data key=\"node_system\">OceanModel</data>\n    </node>\n    <node id=\"n3\">\n      <data key=\"node_name\">ChemistryModel.O3</data>\n      <data key=\"node_kind\">species</data>\n      <data key=\"node_units\">ppb</data>\n      <data key=\"node_system\">ChemistryModel</data>\n    </node>\n    \n    <edge id=\"e1\" source=\"n1\" target=\"n2\">\n      <data key=\"edge_relationship\">variable_map</data>\n      <data key=\"edge_label\">Direct variable mapping</data>\n    </edge>\n    <edge id=\"e2\" source=\"n2\" target=\"n1\">\n      <data key=\"edge_relationship\">operator_compose</data>\n      <data key=\"edge_label\">Heat exchange coupling</data>\n    </edge>\n  </graph>\n</graphml>"
    },
    "cycle_detection": {
