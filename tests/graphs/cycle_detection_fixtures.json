[
  {
    "name": "no_cycles_linear_chain",
    "description": "Simple linear chain with no cycles - should have clear topological ordering",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Linear Chain Test",
        "description": "Simple linear dependency chain for cycle detection baseline"
      },
      "models": {
        "SourceModel": {
          "variables": {"input": {"type": "parameter", "value": 1.0}},
          "equations": []
        },
        "ProcessorModel": {
          "variables": {"intermediate": {"type": "state"}},
          "equations": [{"lhs": "intermediate", "rhs": {"op": "*", "args": ["SourceModel.input", "2.0"]}}]
        },
        "SinkModel": {
          "variables": {"output": {"type": "state"}},
          "equations": [{"lhs": "output", "rhs": {"op": "+", "args": ["ProcessorModel.intermediate", "offset"]}}]
        }
      }
    },
    "expected_analysis": {
      "has_cycles": false,
      "cycles": [],
      "topological_order": ["SourceModel", "ProcessorModel", "SinkModel"],
      "strongly_connected_components": [["SourceModel"], ["ProcessorModel"], ["SinkModel"]],
      "dependency_levels": {
        "SourceModel": 0,
        "ProcessorModel": 1,
        "SinkModel": 2
      }
    }
  },
  {
    "name": "simple_two_node_cycle",
    "description": "Simple bidirectional coupling between two models creating a cycle",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Simple Cycle Test",
        "description": "Two-node cycle for basic cycle detection"
      },
      "models": {
        "ModelA": {
          "variables": {"x": {"type": "state", "units": "dimensionless"}},
          "equations": [{"lhs": "D(x)", "rhs": {"op": "+", "args": ["ModelB.y", "source_a"]}}]
        },
        "ModelB": {
          "variables": {"y": {"type": "state", "units": "dimensionless"}},
          "equations": [{"lhs": "D(y)", "rhs": {"op": "*", "args": ["ModelA.x", "coupling_coeff"]}}]
        }
      },
      "coupling": [
        {
          "source_model": "ModelA",
          "target_model": "ModelB",
          "coupling_type": "variable_map",
          "variable_map": {"x": "input_from_a"}
        },
        {
          "source_model": "ModelB",
          "target_model": "ModelA",
          "coupling_type": "variable_map",
          "variable_map": {"y": "input_from_b"}
        }
      ]
    },
    "expected_analysis": {
      "has_cycles": true,
      "cycles": [["ModelA.x", "ModelB.y", "ModelA.x"]],
      "cycle_types": ["feedback_loop"],
      "topological_order": null,
      "strongly_connected_components": [["ModelA", "ModelB"]],
      "execution_strategy": {
        "method": "fixed_point_iteration",
        "convergence_criteria": "relative_tolerance",
        "max_iterations": 100,
        "tolerance": 1e-6
      }
    }
  },
  {
    "name": "complex_multi_cycle",
    "description": "Multiple overlapping cycles with different cycle lengths",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Complex Multi-Cycle Test",
        "description": "Multiple cycles with different characteristics"
      },
      "models": {
        "AtmosphereModel": {
          "variables": {
            "temperature": {"type": "state", "units": "K"},
            "pressure": {"type": "state", "units": "Pa"}
          },
          "equations": [
            {"lhs": "D(temperature)", "rhs": {"op": "+", "args": ["OceanModel.heat_flux", "LandModel.sensible_heat"]}},
            {"lhs": "D(pressure)", "rhs": {"op": "-", "args": ["pressure", {"op": "/", "args": ["buoyancy", "scale_height"]}]}}
          ]
        },
        "OceanModel": {
          "variables": {
            "sea_surface_temp": {"type": "state", "units": "K"},
            "heat_flux": {"type": "state", "units": "W/m²"}
          },
          "equations": [
            {"lhs": "D(sea_surface_temp)", "rhs": {"op": "-", "args": ["AtmosphereModel.temperature", "sea_surface_temp"]}},
            {"lhs": "heat_flux", "rhs": {"op": "*", "args": ["exchange_coeff", {"op": "-", "args": ["sea_surface_temp", "AtmosphereModel.temperature"]}]}}
          ]
        },
        "LandModel": {
          "variables": {
            "surface_temp": {"type": "state", "units": "K"},
            "sensible_heat": {"type": "state", "units": "W/m²"}
          },
          "equations": [
            {"lhs": "D(surface_temp)", "rhs": {"op": "*", "args": ["thermal_inertia", {"op": "-", "args": ["AtmosphereModel.temperature", "surface_temp"]}]}},
            {"lhs": "sensible_heat", "rhs": {"op": "*", "args": ["heat_transfer_coeff", {"op": "-", "args": ["surface_temp", "AtmosphereModel.temperature"]}]}}
          ]
        },
        "ChemistryModel": {
          "variables": {
            "ozone": {"type": "species", "units": "ppb"},
            "temperature": {"type": "state", "units": "K"}
          },
          "equations": [
            {"lhs": "D(ozone)", "rhs": {"op": "*", "args": ["rate_constant", {"op": "exp", "args": [{"op": "/", "args": ["-activation_energy", "temperature"]}]}]}},
            {"lhs": "temperature", "rhs": "AtmosphereModel.temperature"}
          ]
        }
      },
      "coupling": [
        {
          "source_model": "AtmosphereModel",
          "target_model": "OceanModel",
          "coupling_type": "variable_map",
          "variable_map": {"temperature": "atm_temp_input"}
        },
        {
          "source_model": "OceanModel",
          "target_model": "AtmosphereModel",
          "coupling_type": "variable_map",
          "variable_map": {"heat_flux": "ocean_heat_input"}
        },
        {
          "source_model": "AtmosphereModel",
          "target_model": "LandModel",
          "coupling_type": "variable_map",
          "variable_map": {"temperature": "atm_temp_forcing"}
        },
        {
          "source_model": "LandModel",
          "target_model": "AtmosphereModel",
          "coupling_type": "variable_map",
          "variable_map": {"sensible_heat": "land_heat_input"}
        },
        {
          "source_model": "AtmosphereModel",
          "target_model": "ChemistryModel",
          "coupling_type": "variable_map",
          "variable_map": {"temperature": "temperature_input"}
        }
      ]
    },
    "expected_analysis": {
      "has_cycles": true,
      "cycles": [
        {
          "nodes": ["AtmosphereModel.temperature", "OceanModel.heat_flux", "AtmosphereModel.temperature"],
          "length": 2,
          "type": "atmosphere_ocean_feedback"
        },
        {
          "nodes": ["AtmosphereModel.temperature", "LandModel.sensible_heat", "AtmosphereModel.temperature"],
          "length": 2,
          "type": "atmosphere_land_feedback"
        }
      ],
      "strongly_connected_components": [
        ["AtmosphereModel", "OceanModel", "LandModel"],
        ["ChemistryModel"]
      ],
      "execution_strategy": {
        "scc_1": {
          "components": ["AtmosphereModel", "OceanModel", "LandModel"],
          "method": "jacobi_iteration",
          "reason": "Multiple coupled cycles require simultaneous solution"
        },
        "scc_2": {
          "components": ["ChemistryModel"],
          "method": "direct_evaluation",
          "reason": "No cycles within this component"
        }
      },
      "dependency_analysis": {
        "critical_couplings": [
          {
            "source": "AtmosphereModel.temperature",
            "target": "OceanModel.heat_flux",
            "criticality": "high",
            "reason": "Breaking this coupling would eliminate primary feedback loop"
          },
          {
            "source": "AtmosphereModel.temperature",
            "target": "LandModel.sensible_heat",
            "criticality": "medium",
            "reason": "Secondary feedback loop with slower response time"
          }
        ]
      }
    }
  },
  {
    "name": "self_reference_cycle",
    "description": "Model with explicit self-reference in equations",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Self-Reference Test",
        "description": "Model with self-referential equations"
      },
      "models": {
        "AutocatalyticModel": {
          "variables": {
            "concentration": {"type": "state", "units": "mol/L"}
          },
          "equations": [
            {
              "lhs": "D(concentration)",
              "rhs": {
                "op": "*",
                "args": [
                  "rate_constant",
                  {"op": "*", "args": ["concentration", {"op": "-", "args": ["carrying_capacity", "concentration"]}]}
                ]
              }
            }
          ]
        },
        "DelayModel": {
          "variables": {
            "state": {"type": "state", "units": "dimensionless"}
          },
          "equations": [
            {
              "lhs": "D(state)",
              "rhs": {
                "op": "+",
                "args": [
                  {"op": "delay", "args": ["state", "delay_time"]},
                  "external_input"
                ]
              }
            }
          ]
        }
      }
    },
    "expected_analysis": {
      "has_cycles": true,
      "cycles": [
        {
          "nodes": ["AutocatalyticModel.concentration"],
          "length": 1,
          "type": "self_loop",
          "equation": "D(concentration) = f(concentration, ...)"
        },
        {
          "nodes": ["DelayModel.state"],
          "length": 1,
          "type": "delay_feedback",
          "equation": "D(state) = f(delay(state), ...)"
        }
      ],
      "strongly_connected_components": [
        ["AutocatalyticModel"],
        ["DelayModel"]
      ],
      "execution_strategy": {
        "AutocatalyticModel": {
          "method": "implicit_ode_solver",
          "reason": "Nonlinear self-reference requires implicit treatment",
          "solver_recommendation": "backward_euler"
        },
        "DelayModel": {
          "method": "delay_differential_equation_solver",
          "reason": "Requires history tracking for delay term",
          "solver_recommendation": "method_of_steps"
        }
      }
    }
  },
  {
    "name": "hierarchical_cycles",
    "description": "Cycles at different hierarchical levels - component level vs variable level",
    "esm_file": {
      "version": "0.1.0",
      "metadata": {
        "title": "Hierarchical Cycle Test",
        "description": "Cycles existing at different levels of system hierarchy"
      },
      "models": {
        "SystemA": {
          "subsystems": {
            "SubA1": {
              "variables": {"x1": {"type": "state"}},
              "equations": [{"lhs": "D(x1)", "rhs": {"op": "+", "args": ["SubA2.x2", "input_a1"]}}]
            },
            "SubA2": {
              "variables": {"x2": {"type": "state"}},
              "equations": [{"lhs": "D(x2)", "rhs": {"op": "*", "args": ["SubA1.x1", "coupling_coeff"]}}]
            }
          },
          "variables": {"total": {"type": "observed"}},
          "equations": [{"lhs": "total", "rhs": {"op": "+", "args": ["SubA1.x1", "SubA2.x2"]}}]
        },
        "SystemB": {
          "variables": {"y": {"type": "state"}},
          "equations": [{"lhs": "D(y)", "rhs": {"op": "-", "args": ["SystemA.total", "decay_rate"]}}]
        }
      },
      "coupling": [
        {
          "source_model": "SystemB",
          "target_model": "SystemA.SubA1",
          "coupling_type": "variable_map",
          "variable_map": {"y": "external_forcing"}
        }
      ]
    },
    "expected_analysis": {
      "has_cycles": true,
      "variable_level_cycles": [
        {
          "nodes": ["SystemA.SubA1.x1", "SystemA.SubA2.x2", "SystemA.SubA1.x1"],
          "level": "subsystem",
          "description": "Cycle between subsystems within SystemA"
        }
      ],
      "component_level_cycles": [],
      "hierarchical_analysis": {
        "level_0": {
          "components": ["SystemA", "SystemB"],
          "has_cycles": false,
          "topological_order": ["SystemB", "SystemA"]
        },
        "level_1_SystemA": {
          "components": ["SystemA.SubA1", "SystemA.SubA2"],
          "has_cycles": true,
          "cycles": [["SubA1", "SubA2", "SubA1"]]
        }
      },
      "execution_strategy": {
        "approach": "hierarchical_decomposition",
        "steps": [
          {
            "step": 1,
            "description": "Solve SystemB independently (no cycles at this level)"
          },
          {
            "step": 2,
            "description": "Solve SystemA subsystem cycle using fixed-point iteration",
            "components": ["SubA1", "SubA2"],
            "method": "gauss_seidel"
          },
          {
            "step": 3,
            "description": "Update SystemA total based on subsystem solutions"
          }
        ]
      }
    }
  }
]