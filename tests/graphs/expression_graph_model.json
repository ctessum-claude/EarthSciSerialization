{
  "description": "Expression graph for Advection model with spatial operators",
  "input_file": "minimal_chemistry.esm",
  "input_selector": {
    "type": "model",
    "model": "Advection"
  },
  "expected_nodes": [
    {
      "name": "u_wind",
      "kind": "parameter",
      "units": "m/s",
      "system": "Advection"
    },
    {
      "name": "v_wind",
      "kind": "parameter",
      "units": "m/s",
      "system": "Advection"
    },
    {
      "name": "_var",
      "kind": "state",
      "units": null,
      "system": "Advection",
      "description": "Template variable for any species in advection equation"
    }
  ],
  "expected_edges": [
    {
      "source": "u_wind",
      "target": "_var",
      "relationship": "multiplicative",
      "equation_index": 0,
      "expression": { "op": "*", "args": [{ "op": "-", "args": ["u_wind"] }, { "op": "grad", "args": ["_var"], "dim": "x" }] },
      "label": "D(_var)/dt: u_wind * grad(_var,x)"
    },
    {
      "source": "v_wind",
      "target": "_var",
      "relationship": "multiplicative",
      "equation_index": 0,
      "expression": { "op": "*", "args": [{ "op": "-", "args": ["v_wind"] }, { "op": "grad", "args": ["_var"], "dim": "y" }] },
      "label": "D(_var)/dt: v_wind * grad(_var,y)"
    },
    {
      "source": "_var",
      "target": "_var",
      "relationship": "multiplicative",
      "equation_index": 0,
      "expression": {
        "op": "+", "args": [
          { "op": "*", "args": [{ "op": "-", "args": ["u_wind"] }, { "op": "grad", "args": ["_var"], "dim": "x" }] },
          { "op": "*", "args": [{ "op": "-", "args": ["v_wind"] }, { "op": "grad", "args": ["_var"], "dim": "y" }] }
        ]
      },
      "label": "D(_var)/dt: self-dependency through spatial derivatives"
    }
  ],
  "export_formats": {
    "dot": "digraph {\n  \"u_wind\" -> \"_var\" [label=\"multiplicative (advection x)\"]\n  \"v_wind\" -> \"_var\" [label=\"multiplicative (advection y)\"]\n  \"_var\" -> \"_var\" [label=\"multiplicative (spatial dependency)\"]\n}",
    "mermaid": "graph TD\n  u_wind --> _var\n  v_wind --> _var\n  _var --> _var",
    "json_adjacency": {
      "nodes": ["u_wind", "v_wind", "_var"],
      "adjacency": {
        "u_wind": [
          {"neighbor": "_var", "edge": {"relationship": "multiplicative", "equation_index": 0}}
        ],
        "v_wind": [
          {"neighbor": "_var", "edge": {"relationship": "multiplicative", "equation_index": 0}}
        ],
        "_var": [
          {"neighbor": "_var", "edge": {"relationship": "multiplicative", "equation_index": 0}}
        ]
      }
    }
  }
}