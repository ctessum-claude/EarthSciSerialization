{
  "esm": "0.1.0",
  "metadata": {
    "name": "CouplingEventFunctionalAffectTest",
    "description": "Test CouplingEvent with functional_affect support",
    "authors": ["Claude Sonnet 4"]
  },

  "models": {
    "SystemA": {
      "variables": {
        "x": { "type": "state", "units": "dimensionless", "default": 1.0 },
        "control": { "type": "parameter", "units": "dimensionless", "default": 0.5 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": { "op": "*", "args": [-0.1, "x"] }
        }
      ]
    },
    "SystemB": {
      "variables": {
        "y": { "type": "state", "units": "dimensionless", "default": 2.0 },
        "factor": { "type": "parameter", "units": "dimensionless", "default": 1.0 }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["y"], "wrt": "t" },
          "rhs": { "op": "*", "args": ["factor", { "op": "-", "args": [0.0, "y"] }] }
        }
      ]
    }
  },

  "coupling": [
    {
      "type": "operator_compose",
      "systems": ["SystemA", "SystemB"]
    },
    {
      "type": "event",
      "event_type": "discrete",
      "name": "cross_system_functional_event",
      "trigger": {
        "type": "condition",
        "expression": { "op": ">", "args": [{ "op": "+", "args": ["SystemA.x", "SystemB.y"] }, 2.5] }
      },
      "functional_affect": {
        "handler_id": "cross_system_controller",
        "read_vars": ["SystemA.x", "SystemB.y"],
        "read_params": ["SystemA.control", "SystemB.factor"],
        "modified_params": ["SystemA.control", "SystemB.factor"],
        "config": {
          "control_strategy": "balanced",
          "target_sum": 2.0,
          "adjustment_rate": 0.1
        }
      },
      "discrete_parameters": ["SystemA.control", "SystemB.factor"],
      "description": "Cross-system control using functional affect"
    }
  ],

  "domain": {
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-01T01:00:00Z"
    },
    "initial_conditions": { "type": "constant", "value": 1.0 }
  },

  "solver": {
    "strategy": "strang_threads",
    "config": {
      "timestep": 0.1
    }
  }
}