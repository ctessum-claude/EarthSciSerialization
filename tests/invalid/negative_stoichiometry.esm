{
  "esm": "0.1.0",
  "metadata": {
    "name": "NegativeStoichiometryTest",
    "description": "Reaction with negative or zero stoichiometry values",
    "authors": ["Test Author"]
  },
  "reaction_systems": {
    "TestRxns": {
      "species": {
        "A": {"units": "mol/mol", "default": 1e-6, "description": "Species A"},
        "B": {"units": "mol/mol", "default": 2e-6, "description": "Species B"}
      },
      "parameters": {
        "k": {"units": "1/s", "default": 1e-3}
      },
      "reactions": [
        {
          "id": "R1",
          "substrates": [
            {"species": "A", "stoichiometry": -1}
          ],
          "products": [
            {"species": "B", "stoichiometry": 0}
          ],
          "rate": "k"
        }
      ]
    }
  }
}