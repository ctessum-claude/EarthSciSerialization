{
  "esm": "0.1.0",
  "metadata": {
    "name": "SpatialDiffusionTest",
    "description": "1D diffusion equation with spatial operators",
    "authors": ["Test Suite"],
    "created": "2026-02-14T00:00:00Z",
    "tags": ["test", "spatial", "pde", "diffusion"]
  },
  "models": {
    "DiffusionSystem": {
      "reference": {
        "notes": "Heat equation: ∂u/∂t = D * ∂²u/∂x² with Dirichlet boundary conditions"
      },
      "variables": {
        "u": {
          "type": "field",
          "domain": "spatial_1d",
          "units": "K",
          "default": "initial_temperature_profile",
          "description": "Temperature field"
        },
        "D": {
          "type": "parameter",
          "units": "m^2/s",
          "default": 0.1,
          "description": "Diffusion coefficient"
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["u"], "wrt": "t" },
          "rhs": { "op": "*", "args": [
            "D",
            { "op": "D2", "args": ["u"], "wrt": "x" }
          ]}
        }
      ]
    }
  },
  "domain": {
    "spatial": {
      "dimensions": ["x"],
      "x": { "start": 0.0, "end": 1.0, "points": 101 }
    },
    "temporal": { "start": 0.0, "end": 1.0, "step": 0.001 },
    "boundary_conditions": {
      "u": {
        "x_left": { "type": "dirichlet", "value": 0.0 },
        "x_right": { "type": "dirichlet", "value": 0.0 }
      }
    },
    "initial_conditions": {
      "type": "functional",
      "u": {
        "formula": "sin(pi * x)",
        "description": "Sine wave initial temperature profile"
      }
    }
  },
  "solver": {
    "strategy": "strang_threads",
    "config": {
      "spatial_discretization": "finite_difference_2nd_order",
      "time_algorithm": "CVODE_BDF",
      "rtol": 1e-6,
      "atol": 1e-8
    }
  }
}