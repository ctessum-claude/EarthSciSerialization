        "Oscillator1.v1": [0.0, "verify_numerically", "verify_numerically", "verify_numerically", "verify_numerically"],
        "Oscillator2.x2": [-0.5, "verify_numerically", "verify_numerically", "verify_numerically", "verify_numerically"],
        "Oscillator2.v2": [0.0, "verify_numerically", "verify_numerically", "verify_numerically", "verify_numerically"]
      }
