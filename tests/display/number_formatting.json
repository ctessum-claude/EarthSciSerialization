[
  {
    "description": "Integer formatting (no fractional part)",
    "test_cases": [
      {
        "input": 3,
        "unicode": "3",
        "latex": "3",
        "ascii": "3"
      },
      {
        "input": -1,
        "unicode": "−1",
        "latex": "-1",
        "ascii": "-1"
      },
      {
        "input": 1000,
        "unicode": "1000",
        "latex": "1000",
        "ascii": "1000"
      },
      {
        "input": 0,
        "unicode": "0",
        "latex": "0",
        "ascii": "0"
      }
    ]
  },
  {
    "description": "Decimal notation (1-4 significant digits)",
    "test_cases": [
      {
        "input": 0.005,
        "unicode": "0.005",
        "latex": "0.005",
        "ascii": "0.005"
      },
      {
        "input": 298.15,
        "unicode": "298.15",
        "latex": "298.15",
        "ascii": "298.15"
      },
      {
        "input": 3.14,
        "unicode": "3.14",
        "latex": "3.14",
        "ascii": "3.14"
      }
    ]
  },
  {
    "description": "Scientific notation (|value| < 0.01 or |value| >= 10000)",
    "test_cases": [
      {
        "input": 1.8e-12,
        "unicode": "1.8×10⁻¹²",
        "latex": "1.8 \\times 10^{-12}",
        "ascii": "1.8e-12"
      },
      {
        "input": 2.46e19,
        "unicode": "2.46×10¹⁹",
        "latex": "2.46 \\times 10^{19}",
        "ascii": "2.46e19"
      },
      {
        "input": 0.001,
        "unicode": "1.0×10⁻³",
        "latex": "1.0 \\times 10^{-3}",
        "ascii": "1.0e-3"
      },
      {
        "input": 15000,
        "unicode": "1.5×10⁴",
        "latex": "1.5 \\times 10^{4}",
        "ascii": "1.5e4"
      }
    ]
  },
  {
    "description": "Exactly zero",
    "test_cases": [
      {
        "input": 0.0,
        "unicode": "0",
        "latex": "0",
        "ascii": "0"
      },
      {
        "input": -0.0,
        "unicode": "0",
        "latex": "0",
        "ascii": "0"
      }
    ]
  },
  {
    "description": "Edge cases for scientific notation threshold",
    "test_cases": [
      {
        "input": 0.01,
        "unicode": "0.01",
        "latex": "0.01",
        "ascii": "0.01",
        "note": "Exactly at threshold, use decimal"
      },
      {
        "input": 0.009999,
        "unicode": "1.0×10⁻²",
        "latex": "1.0 \\times 10^{-2}",
        "ascii": "1.0e-2",
        "note": "Below threshold, use scientific"
      },
      {
        "input": 9999.99,
        "unicode": "9999.99",
        "latex": "9999.99",
        "ascii": "9999.99",
        "note": "Below 10000 threshold, use decimal"
      },
      {
        "input": 10000,
        "unicode": "1.0×10⁴",
        "latex": "1.0 \\times 10^{4}",
        "ascii": "1.0e4",
        "note": "At threshold, use scientific"
      }
    ]
  },
  {
    "description": "Negative numbers",
    "test_cases": [
      {
        "input": -3.14,
        "unicode": "−3.14",
        "latex": "-3.14",
        "ascii": "-3.14"
      },
      {
        "input": -1.8e-12,
        "unicode": "−1.8×10⁻¹²",
        "latex": "-1.8 \\times 10^{-12}",
        "ascii": "-1.8e-12"
      }
    ]
  },
  {
    "description": "Special values",
    "test_cases": [
      {
        "input": "Infinity",
        "unicode": "∞",
        "latex": "\\infty",
        "ascii": "inf"
      },
      {
        "input": "-Infinity",
        "unicode": "−∞",
        "latex": "-\\infty",
        "ascii": "-inf"
      },
      {
        "input": "NaN",
        "unicode": "NaN",
        "latex": "\\text{NaN}",
        "ascii": "NaN"
      }
    ]
  }
]