[
  {
    "description": "Time derivatives using frac notation",
    "test_cases": [
      {
        "input": {"op": "D", "args": ["O3"], "wrt": "t"},
        "latex": "\\frac{\\partial \\mathrm{O_3}}{\\partial t}",
        "description": "Species time derivative with frac and mathrm"
      },
      {
        "input": {"op": "D", "args": ["concentration"], "wrt": "t"},
        "latex": "\\frac{\\partial \\mathrm{concentration}}{\\partial t}",
        "description": "Variable time derivative with mathrm formatting"
      }
    ]
  },
  {
    "description": "Spatial gradients",
    "test_cases": [
      {
        "input": {"op": "grad", "args": ["T"], "dim": "x"},
        "latex": "\\frac{\\partial T}{\\partial x}",
        "description": "Temperature gradient - single letters don't need mathrm"
      },
      {
        "input": {"op": "grad", "args": ["pressure"], "dim": "y"},
        "latex": "\\frac{\\partial \\mathrm{pressure}}{\\partial y}",
        "description": "Multi-letter variable needs mathrm"
      }
    ]
  },
  {
    "description": "Fractions for division",
    "test_cases": [
      {
        "input": {"op": "/", "args": ["a", "b"]},
        "latex": "\\frac{a}{b}",
        "description": "Simple division as fraction"
      },
      {
        "input": {"op": "/", "args": [{"op": "+", "args": ["a", "b"]}, "c"]},
        "latex": "\\frac{a + b}{c}",
        "description": "Complex numerator"
      },
      {
        "input": {"op": "/", "args": ["a", {"op": "*", "args": ["b", "c"]}]},
        "latex": "\\frac{a}{b c}",
        "description": "Complex denominator - multiplication uses space in LaTeX"
      }
    ]
  },
  {
    "description": "Chemical species with subscripts using mathrm",
    "test_cases": [
      {
        "input": "O3",
        "latex": "\\mathrm{O_3}",
        "description": "Ozone with subscript and roman formatting"
      },
      {
        "input": "NO2",
        "latex": "\\mathrm{NO_2}",
        "description": "Nitrogen dioxide"
      },
      {
        "input": "CH2O",
        "latex": "\\mathrm{CH_2O}",
        "description": "Formaldehyde with subscript on hydrogen"
      },
      {
        "input": "H2O2",
        "latex": "\\mathrm{H_2O_2}",
        "description": "Hydrogen peroxide with multiple subscripts"
      }
    ]
  },
  {
    "description": "Multiplication - implicit (space) in LaTeX",
    "test_cases": [
      {
        "input": {"op": "*", "args": ["a", "b"]},
        "latex": "a b",
        "description": "Multiplication by juxtaposition"
      },
      {
        "input": {"op": "*", "args": ["k", "\\mathrm{O_3}", "\\mathrm{NO}"]},
        "latex": "k \\mathrm{O_3} \\mathrm{NO}",
        "description": "Rate constant times species concentrations"
      }
    ]
  },
  {
    "description": "Scientific notation",
    "test_cases": [
      {
        "input": 1.8e-12,
        "latex": "1.8 \\times 10^{-12}",
        "description": "Scientific notation with times symbol"
      },
      {
        "input": 2.46e19,
        "latex": "2.46 \\times 10^{19}",
        "description": "Large number in scientific notation"
      }
    ]
  },
  {
    "description": "Mathematical operators",
    "test_cases": [
      {
        "input": {"op": "exp", "args": [{"op": "/", "args": ["-E", "RT"]}]},
        "latex": "\\exp\\left(\\frac{-E}{RT}\\right)",
        "description": "Exponential function with fraction argument"
      },
      {
        "input": {"op": "sqrt", "args": ["x"]},
        "latex": "\\sqrt{x}",
        "description": "Square root"
      },
      {
        "input": {"op": "sin", "args": ["\\theta"]},
        "latex": "\\sin(\\theta)",
        "description": "Sine function"
      }
    ]
  },
  {
    "description": "Exponents and superscripts",
    "test_cases": [
      {
        "input": {"op": "^", "args": ["x", 2]},
        "latex": "x^2",
        "description": "Simple squared"
      },
      {
        "input": {"op": "^", "args": ["x", {"op": "+", "args": ["n", 1]}]},
        "latex": "x^{n + 1}",
        "description": "Complex exponent with braces"
      }
    ]
  },
  {
    "description": "Nabla operators",
    "test_cases": [
      {
        "input": {"op": "div", "args": ["\\mathbf{v}"]},
        "latex": "\\nabla \\cdot \\mathbf{v}",
        "description": "Divergence with vector notation"
      },
      {
        "input": {"op": "laplacian", "args": ["T"]},
        "latex": "\\nabla^2 T",
        "description": "Laplacian operator"
      }
    ]
  },
  {
    "description": "Complex expressions",
    "test_cases": [
      {
        "input": {
          "op": "=",
          "args": [
            {"op": "D", "args": ["O3"], "wrt": "t"},
            {"op": "+", "args": [
              {"op": "*", "args": [{"op": "-", "args": ["k_{NO_O3}"]}, "\\mathrm{O_3}", "\\mathrm{NO}", "M"]},
              {"op": "*", "args": ["j_{NO2}", "\\mathrm{NO_2}"]}
            ]}
          ]
        },
        "latex": "\\frac{\\partial \\mathrm{O_3}}{\\partial t} = -k_{NO_O3} \\mathrm{O_3} \\mathrm{NO} M + j_{NO2} \\mathrm{NO_2}",
        "description": "Complete atmospheric chemistry ODE"
      }
    ]
  },
  {
    "description": "Special formatting rules",
    "formatting_rules": {
      "species_names": "Use \\mathrm{} for multi-character species names",
      "single_variables": "Single letters (T, x, k) don't need \\mathrm{}",
      "subscripts": "Use underscore: O_3, NO_2",
      "multiplication": "Use space for implicit multiplication",
      "fractions": "Use \\frac{}{} for all division",
      "functions": "Use backslash prefix: \\exp, \\sin, \\log",
      "derivatives": "Use \\frac{\\partial}{\\partial} notation"
    }
  }
]