  {
    "name": "Complex nested expressions",
    "tests": [
      {
        "input": { "op": "exp", "args": [{ "op": "/", "args": [{ "op": "*", "args": [-1370, { "op": "log", "args": ["T"] }] }, "R"] }] },
        "unicode": "exp(−1370·ln(T)/R)",
        "latex": "\\exp\\left(\\frac{-1370 \\cdot \\ln(T)}{R}\\right)",
        "ascii": "exp(-1370 * log(T) / R)"
      },
      {
        "input": { "op": "+", "args": [
          { "op": "*", "args": ["A", { "op": "sin", "args": [{ "op": "*", "args": ["ω", "t"] }] }] },
          { "op": "*", "args": ["B", { "op": "cos", "args": [{ "op": "*", "args": ["ω", "t"] }] }] }
        ] },
        "unicode": "A·sin(ω·t) + B·cos(ω·t)",
        "latex": "A \\cdot \\sin(\\omega \\cdot t) + B \\cdot \\cos(\\omega \\cdot t)",
        "ascii": "A * sin(omega * t) + B * cos(omega * t)"
      },
      {
        "input": { "op": "sqrt", "args": [{ "op": "+", "args": [
          { "op": "^", "args": ["a", 2] },
          { "op": "^", "args": ["b", 2] },
          { "op": "*", "args": [2, "a", "b", { "op": "cos", "args": ["γ"] }] }
        ] }] },
        "unicode": "√(a² + b² + 2·a·b·cos(γ))",
        "latex": "\\sqrt{a^{2} + b^{2} + 2 \\cdot a \\cdot b \\cdot \\cos(\\gamma)}",
        "ascii": "sqrt(a^2 + b^2 + 2 * a * b * cos(gamma))"
      }
    ]
  }
]