  {
    "description": "Multiplication using middle dot",
    "test_cases": [
      {
        "input": {"op": "*", "args": ["a", "b"]},
        "unicode": "a·b",
        "description": "Binary multiplication"
      },
      {
        "input": {"op": "*", "args": ["k", "O3", "NO"]},
        "unicode": "k·O₃·NO",
        "description": "Ternary multiplication with chemical species"
      }
    ]
  },
  {
    "description": "Minus sign (not hyphen) for subtraction and negation",
    "test_cases": [
      {
        "input": {"op": "-", "args": ["a"]},
        "unicode": "−a",
        "description": "Unary negation with proper minus sign"
      },
      {
        "input": {"op": "+", "args": ["a", {"op": "-", "args": ["b"]}]},
        "unicode": "a − b",
        "description": "Subtraction with proper minus sign"
      }
    ]
  },
  {
    "description": "Pre operator (event handling)",
    "test_cases": [
      {
        "input": {"op": "Pre", "args": ["x"]},
        "unicode": "Pre(x)",
        "description": "Pre-event variable value"
      }
    ]
  },
  {
    "description": "Mathematical operators and symbols",
    "test_cases": [
      {
        "input": {"op": "div", "args": ["velocity_field"]},
        "unicode": "∇·velocity_field",
