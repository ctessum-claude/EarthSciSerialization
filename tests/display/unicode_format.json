      {
        "input": "O3",
        "unicode": "O₃",
        "description": "Ozone with subscript"
      },
      {
        "input": "NO2",
        "unicode": "NO₂",
        "description": "Nitrogen dioxide with subscript"
      },
      {
        "input": "CH2O",
        "unicode": "CH₂O",
        "description": "Formaldehyde with subscript on hydrogen"
      },
      {
        "input": "H2O2",
        "unicode": "H₂O₂",
        "description": "Hydrogen peroxide with multiple subscripts"
      }
    ]
  },
  {
    "description": "Exponents and superscripts",
    "test_cases": [
      {
        "input": {"op": "^", "args": ["x", 2]},
        "unicode": "x²",
        "description": "Squared using superscript"
      },
      {
        "input": {"op": "^", "args": ["x", 3]},
        "unicode": "x³",
        "description": "Cubed using superscript"
      },
      {
        "input": {"op": "^", "args": ["x", "n"]},
        "unicode": "x^n",
        "description": "Variable exponent using caret notation"
      }
    ]
  },
  {
    "description": "Parentheses minimization based on precedence",
    "test_cases": [
      {
        "input": {"op": "+", "args": [{"op": "*", "args": ["a", "b"]}, "c"]},
        "unicode": "a·b + c",
        "description": "No parentheses needed - multiplication has higher precedence"
      },
      {
        "input": {"op": "*", "args": ["a", {"op": "+", "args": ["b", "c"]}]},
        "unicode": "a·(b + c)",
        "description": "Parentheses needed for lower precedence operation"
      }
    ]
  },
  {
    "description": "Complex expressions",
    "test_cases": [
      {
        "input": {
          "op": "=",
          "args": [
            {"op": "D", "args": ["O₃"], "wrt": "t"},
            {"op": "+", "args": [
              {"op": "*", "args": [{"op": "-", "args": ["k_NO_O3"]}, "O₃", "NO", "M"]},
              {"op": "*", "args": ["jNO2", "NO₂"]}
            ]}
          ]
        },
        "unicode": "∂O₃/∂t = −k_NO_O3·O₃·NO·M + jNO2·NO₂",
        "description": "Complete ODE with chemical species and parameters"
      }
    ]
  }
]