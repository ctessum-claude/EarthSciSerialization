{
  "description": "Test cases for chemical element recognition in pretty-printing",
  "test_cases": [
    {
      "name": "simple_molecule",
      "input": "CO2",
      "expected_output": "CO₂",
      "format": "unicode",
      "description": "Carbon dioxide should have subscript 2"
    },
    {
      "name": "water",
      "input": "H2O",
      "expected_output": "H₂O",
      "format": "unicode",
      "description": "Water molecule with subscript 2"
    },
    {
      "name": "complex_molecule",
      "input": "C6H12O6",
      "expected_output": "C₆H₁₂O₆",
      "format": "unicode",
      "description": "Glucose with multiple subscripts"
    },
    {
      "name": "charged_ion",
      "input": "Ca2+",
      "expected_output": "Ca²⁺",
      "format": "unicode",
      "description": "Calcium ion with charge"
    },
    {
      "name": "negative_ion",
      "input": "SO4-2",
      "expected_output": "SO₄²⁻",
      "format": "unicode",
      "description": "Sulfate ion with negative charge"
    },
    {
      "name": "latex_format",
      "input": "NO2",
      "expected_output": "\\text{NO}_2",
      "format": "latex",
      "description": "LaTeX format for nitrogen dioxide"
    },
    {
      "name": "ascii_format",
      "input": "H2SO4",
      "expected_output": "H2SO4",
      "format": "ascii",
      "description": "ASCII format unchanged"
    }
  ]
}