{
  "esm": "0.1.0",
  "metadata": {
    "name": "MultiDomainTest",
    "description": "Test fixture exercising multiple named domains with different dimensionality (3D, 2D, 0D)",
    "authors": ["EarthSciML"],
    "created": "2026-04-09T00:00:00Z",
    "tags": ["multi-domain", "mixed-dimension", "test-fixture"]
  },

  "models": {
    "Atmosphere3D": {
      "domain": "atmos",
      "variables": {
        "T": { "type": "state", "units": "K", "default": 288.0, "description": "Temperature" },
        "q": { "type": "parameter", "units": "K/s", "default": 0.0, "description": "Heating rate" }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["T"], "wrt": "t" },
          "rhs": "q"
        }
      ]
    },

    "Surface2D": {
      "domain": "surface",
      "variables": {
        "T_sfc": { "type": "state", "units": "K", "default": 300.0, "description": "Surface temperature" },
        "albedo": { "type": "parameter", "units": "1", "default": 0.3, "description": "Surface albedo" },
        "net_flux": { "type": "parameter", "units": "W/m^2", "default": 0.0, "description": "Net surface flux" }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["T_sfc"], "wrt": "t" },
          "rhs": { "op": "/", "args": ["net_flux", 2.0e6] }
        }
      ]
    },

    "Column1D": {
      "domain": "column",
      "variables": {
        "moisture": { "type": "state", "units": "kg/m^2", "default": 20.0, "description": "Column-integrated moisture" },
        "precip_rate": { "type": "parameter", "units": "kg/(m^2*s)", "default": 0.0, "description": "Precipitation rate" }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["moisture"], "wrt": "t" },
          "rhs": { "op": "-", "args": ["precip_rate"] }
        }
      ]
    },

    "PointProcess": {
      "domain": null,
      "variables": {
        "T_in": { "type": "parameter", "units": "K", "default": 288.0, "description": "Input temperature" },
        "T_sfc_in": { "type": "parameter", "units": "K", "default": 300.0, "description": "Surface temperature input" },
        "flux_out": {
          "type": "observed", "units": "W/m^2",
          "expression": {
            "op": "*",
            "args": [5.67e-8, { "op": "-", "args": [
              { "op": "^", "args": ["T_sfc_in", 4] },
              { "op": "^", "args": ["T_in", 4] }
            ]}]
          },
          "description": "Radiative flux (Stefan-Boltzmann)"
        }
      },
      "equations": []
    }
  },

  "domains": {
    "atmos": {
      "temporal": { "start": "2024-06-01T00:00:00Z", "end": "2024-06-02T00:00:00Z" },
      "spatial": {
        "lon": { "min": -10.0, "max": 10.0, "units": "degrees", "grid_spacing": 1.0 },
        "lat": { "min": 40.0, "max": 50.0, "units": "degrees", "grid_spacing": 1.0 },
        "lev": { "min": 0.0, "max": 30000.0, "units": "m", "grid_spacing": 1000.0 }
      },
      "spatial_ref": "WGS84",
      "initial_conditions": { "type": "constant", "value": 288.0 },
      "boundary_conditions": [
        { "type": "periodic", "dimensions": ["lon"] },
        { "type": "zero_gradient", "dimensions": ["lat", "lev"] }
      ],
      "element_type": "Float64"
    },
    "surface": {
      "temporal": { "start": "2024-06-01T00:00:00Z", "end": "2024-06-02T00:00:00Z" },
      "spatial": {
        "lon": { "min": -10.0, "max": 10.0, "units": "degrees", "grid_spacing": 0.5 },
        "lat": { "min": 40.0, "max": 50.0, "units": "degrees", "grid_spacing": 0.5 }
      },
      "spatial_ref": "WGS84",
      "initial_conditions": { "type": "constant", "value": 300.0 },
      "boundary_conditions": [
        { "type": "periodic", "dimensions": ["lon"] },
        { "type": "zero_gradient", "dimensions": ["lat"] }
      ],
      "element_type": "Float64"
    },
    "column": {
      "temporal": { "start": "2024-06-01T00:00:00Z", "end": "2024-06-02T00:00:00Z" },
      "spatial": {
        "z": { "min": 0.0, "max": 30000.0, "units": "m", "grid_spacing": 500.0 }
      },
      "initial_conditions": { "type": "constant", "value": 20.0 },
      "boundary_conditions": [
        { "type": "zero_gradient", "dimensions": ["z"] }
      ],
      "element_type": "Float64"
    }
  },

  "solver": {
    "strategy": "strang_serial",
    "config": {
      "stiff_algorithm": "Rosenbrock23",
      "timestep": 300.0
    }
  }
}
