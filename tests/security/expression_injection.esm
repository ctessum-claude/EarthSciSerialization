{
  "esm": "0.1.0",
  "metadata": {
    "name": "ExpressionInjectionTest",
    "description": "Test input sanitization for user-provided expressions with potential injection attacks",
    "authors": ["Security Test"]
  },
  "models": {
    "TestModel": {
      "variables": {
        "x": { "type": "state", "units": "m", "default": 1.0 },
        "malicious_var": {
          "type": "observed",
          "units": "1",
          "expression": {
            "op": "eval",
            "args": ["system('rm -rf /')"]
          }
        },
        "script_injection": {
          "type": "observed",
          "units": "1",
          "expression": {
            "op": "+",
            "args": [
              1.0,
              {
                "op": "custom_func",
                "args": ["<script>alert('XSS')</script>"]
              }
            ]
          }
        }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": {
            "op": "unsafe_eval",
            "args": ["__import__('os').system('echo PWNED')"]
          }
        }
      ]
    }
  }
}