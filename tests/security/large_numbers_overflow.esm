{
  "esm": "0.1.0",
  "metadata": {
    "name": "LargeNumbersOverflow",
    "description": "Test numerical overflow with very large numbers that may exceed floating-point limits",
    "authors": ["Security Test"]
  },
  "models": {
    "TestModel": {
      "variables": {
        "x": { "type": "state", "units": "m", "default": 1.7976931348623157e+308 },
        "y": { "type": "state", "units": "m", "default": -1.7976931348623157e+308 },
        "z": { "type": "parameter", "units": "1", "default":  }
      },
      "equations": [
        {
          "lhs": { "op": "D", "args": ["x"], "wrt": "t" },
          "rhs": { "op": "*", "args": [1.7976931348623157e+308, 1.7976931348623157e+308] }
        },
        {
          "lhs": { "op": "D", "args": ["y"], "wrt": "t" },
          "rhs": { "op": "exp", "args": [1000000] }
        }
      ]
    }
  },
  "reaction_systems": {
    "TestReactions": {
      "species": {
        "A": { "units": "mol/mol", "default": 1.0e-9, "description": "Species A" }
      },
      "parameters": {
        "huge_rate": { "units": "1/s", "default": 1..0, "description": "Extremely large rate constant" }
      },
      "reactions": [
        {
          "id": "R_overflow",
          "name": "overflow_test",
          "substrates": [ { "species": "A", "stoichiometry": 1 } ],
          "products": [ { "species": "A", "stoichiometry": 2 } ],
          "rate": { "op": "*", "args": ["huge_rate", { "op": "pow", "args": [10, 1000] }] }
        }
      ]
    }
  }
}