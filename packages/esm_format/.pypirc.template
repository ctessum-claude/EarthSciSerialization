# Template .pypirc file for PyPI publishing
# Copy this file to ~/.pypirc and fill in your credentials
# WARNING: Keep your actual .pypirc file private and never commit it!

[distutils]
index-servers =
    pypi
    testpypi

[pypi]
repository = https://upload.pypi.org/legacy/
username = __token__
password = <YOUR_PYPI_API_TOKEN>

[testpypi]
repository = https://test.pypi.org/legacy/
username = __token__
password = <YOUR_TESTPYPI_API_TOKEN>

# Instructions:
# 1. Create API tokens at:
#    - PyPI: https://pypi.org/manage/account/token/
#    - TestPyPI: https://test.pypi.org/manage/account/token/
# 2. Replace <YOUR_PYPI_API_TOKEN> and <YOUR_TESTPYPI_API_TOKEN> with your actual tokens
# 3. Copy this file to ~/.pypirc
# 4. Set appropriate permissions: chmod 600 ~/.pypirc