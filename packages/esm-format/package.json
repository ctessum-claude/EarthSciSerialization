{
  "name": "esm-format",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript types and utilities for EarthSciML Serialization Format",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:rollup && npm run build:copy-types",
    "build:clean": "rm -rf dist/esm dist/cjs dist/bundled.d.ts",
    "build:rollup": "rollup -c",
    "build:copy-types": "cp dist/core.d.ts dist/esm/index.d.ts && cp dist/core.d.ts dist/cjs/index.d.ts",
    "build:types": "tsc --project tsconfig.build.json",
    "build:legacy": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:accessibility": "playwright test tests/interactive/accessibility/",
    "test:performance": "playwright test tests/interactive/performance/",
    "test:all": "npm run test && npm run test:e2e",
    "dev:demo": "node -e \"require('./dist/demo/demo-pages.js').createDemoServer()\"",
    "generate-types": "json2ts -i ../../esm-schema.json -o src/generated.ts",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test:ci": "npm run test -- --run",
    "publish:dry-run": "npm publish --dry-run",
    "publish:beta": "npm publish --tag beta",
    "publish:release": "npm publish"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "earth-science",
    "scientific-modeling",
    "serialization",
    "typescript",
    "modeling",
    "chemistry",
    "atmospheric-science",
    "json-schema",
    "expressions",
    "mathematical-modeling"
  ],
  "author": "EarthSciML Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/user/EarthSciSerialization.git",
    "directory": "packages/esm-format"
  },
  "bugs": {
    "url": "https://github.com/user/EarthSciSerialization/issues"
  },
  "homepage": "https://github.com/user/EarthSciSerialization#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20.0.0",
    "jsdom": "^22.0.0",
    "json-schema-to-typescript": "^13.0.0",
    "playwright": "^1.58.2",
    "rollup": "^4.57.1",
    "rollup-plugin-dts": "^6.3.0",
    "typescript": "^5.0.0",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "d3-force": "^3.0.0",
    "solid-element": "^1.9.1",
    "solid-js": "^1.8.0"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  }
}
