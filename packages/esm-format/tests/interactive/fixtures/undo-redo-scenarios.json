{
  "commandPatterns": {
    "description": "Command pattern implementations for undo/redo functionality",
    "commands": [
      {
        "type": "EditCommand",
        "interface": {
          "id": "string",
          "type": "edit",
          "target": { "path": "number[]", "type": "string" },
          "oldValue": "any",
          "newValue": "any",
          "timestamp": "number",
          "canMerge": "boolean",
          "groupId": "string?"
        },
        "implementation": {
          "execute": "Set value at path to newValue",
          "undo": "Set value at path to oldValue",
          "redo": "Call execute()",
          "canMergeWith": "Check if same path, within time threshold, both edits"
        }
      },
      {
        "type": "WrapCommand",
        "interface": {
          "id": "string",
          "type": "wrap",
          "target": { "path": "number[]" },
          "wrapper": "Expression",
          "originalValue": "any",
          "timestamp": "number",
          "canMerge": false
        },
        "implementation": {
          "execute": "Replace target with wrapper, insert original as placeholder",
          "undo": "Replace wrapped expression with originalValue",
          "redo": "Call execute()"
        }
      },
      {
        "type": "DeleteCommand",
        "interface": {
          "id": "string",
          "type": "delete",
          "target": { "path": "number[]" },
          "deletedValue": "any",
          "parentContext": "any",
          "timestamp": "number",
          "canMerge": false
        },
        "implementation": {
          "execute": "Remove target from parent, handle parent simplification",
          "undo": "Restore deleted value at target path",
          "redo": "Call execute()"
        }
      },
      {
        "type": "ReorderCommand",
        "interface": {
          "id": "string",
          "type": "reorder",
          "parentPath": "number[]",
          "sourceIndex": "number",
          "targetIndex": "number",
          "canMerge": false
        },
        "implementation": {
          "execute": "Move element from sourceIndex to targetIndex",
          "undo": "Move element from targetIndex to sourceIndex",
          "redo": "Call execute()"
        }
      }
    ]
  },

  "scenariosByComplexity": {
    "simple": [
      {
        "name": "single_number_edit",
        "initialExpression": 42,
        "sequence": [
          {
            "action": "edit",
            "path": [],
            "newValue": 100,
            "commandId": "edit-1"
          }
        ],
        "undoTest": {
          "steps": 1,
          "finalState": 42
        },
        "redoTest": {
          "steps": 1,
          "finalState": 100
        }
      },
      {
        "name": "variable_rename",
        "initialExpression": "temperature",
        "sequence": [
          {
            "action": "edit",
            "path": [],
            "newValue": "temp",
            "commandId": "edit-1"
          }
        ],
        "undoTest": {
          "steps": 1,
          "finalState": "temperature"
        }
      }
    ],

    "moderate": [
      {
        "name": "binary_operation_modifications",
        "initialExpression": { "op": "+", "args": ["a", "b"] },
        "sequence": [
          {
            "action": "edit",
            "path": [0],
            "newValue": "x",
            "commandId": "edit-1"
          },
          {
            "action": "edit",
            "path": [1],
            "newValue": "y",
            "commandId": "edit-2"
          },
          {
            "action": "wrap",
            "path": [0],
            "wrapper": { "op": "sin", "args": ["PLACEHOLDER"] },
            "commandId": "wrap-1"
          }
        ],
        "undoTest": {
          "steps": 3,
          "intermediateStates": [
            { "op": "+", "args": ["x", "y"] },
            { "op": "+", "args": ["a", "y"] },
            { "op": "+", "args": ["a", "b"] }
          ]
        }
      },
      {
        "name": "commutative_reordering",
        "initialExpression": { "op": "*", "args": ["a", "b", "c"] },
        "sequence": [
          {
            "action": "reorder",
            "parentPath": [],
            "sourceIndex": 0,
            "targetIndex": 2,
            "commandId": "reorder-1"
          }
        ],
        "finalExpression": { "op": "*", "args": ["b", "c", "a"] },
        "undoTest": {
          "steps": 1,
          "finalState": { "op": "*", "args": ["a", "b", "c"] }
        }
      }
    ],

    "complex": [
      {
        "name": "nested_expression_edits",
        "initialExpression": {
          "op": "+",
          "args": [
            { "op": "*", "args": ["a", { "op": "sin", "args": ["x"] }] },
            { "op": "/", "args": ["b", "c"] }
          ]
        },
        "sequence": [
          {
            "action": "edit",
            "path": [0, 1, 0],
            "newValue": "theta",
            "commandId": "edit-1"
          },
          {
            "action": "unwrap",
            "path": [0, 1],
            "commandId": "unwrap-1"
          },
          {
            "action": "edit",
            "path": [1, 0],
            "newValue": "numerator",
            "commandId": "edit-2"
          },
          {
            "action": "wrap",
            "path": [1],
            "wrapper": { "op": "()", "args": ["PLACEHOLDER"] },
            "commandId": "wrap-1"
          }
        ],
        "undoTest": {
          "steps": 4,
          "verifyEachStep": true
        }
      },
      {
        "name": "rapid_typing_merge",
        "initialExpression": "",
        "sequence": [
          { "action": "type", "char": "h", "timestamp": 1000, "commandId": "type-1" },
          { "action": "type", "char": "e", "timestamp": 1050, "commandId": "type-2" },
          { "action": "type", "char": "l", "timestamp": 1100, "commandId": "type-3" },
          { "action": "type", "char": "l", "timestamp": 1150, "commandId": "type-4" },
          { "action": "type", "char": "o", "timestamp": 1200, "commandId": "type-5" }
        ],
        "commandMerging": {
          "enabled": true,
          "threshold": 500,
          "mergeIntoId": "type-sequence-1"
        },
        "undoTest": {
          "steps": 1,
          "finalState": "",
          "description": "All typing should undo as single operation"
        }
      }
    ]
  },

  "memoryManagement": {
    "stackLimits": [
      {
        "name": "default_stack_size",
        "limit": 50,
        "behavior": "discard_oldest"
      },
      {
        "name": "memory_pressure_limit",
        "limit": 20,
        "behavior": "compress_old_commands"
      },
      {
        "name": "minimal_stack",
        "limit": 3,
        "testScenario": "Generate 10 operations, verify only last 3 are undoable"
      }
    ],

    "commandCompression": {
      "consecutiveEdits": {
        "threshold": 10,
        "action": "merge_into_single_command"
      },
      "oldCommands": {
        "age": "10_minutes",
        "action": "store_final_state_only"
      }
    }
  },

  "errorRecovery": {
    "scenarios": [
      {
        "name": "invalid_undo_state",
        "description": "What happens when undo produces invalid state",
        "sequence": [
          { "action": "delete", "path": [0], "commandId": "delete-1" },
          { "action": "edit", "path": [0], "commandId": "edit-1" }
        ],
        "corruption": "manually_corrupt_undo_stack",
        "expectedBehavior": "graceful_fallback_to_last_valid_state"
      },
      {
        "name": "command_execution_failure",
        "description": "Handle undo/redo command that fails to execute",
        "failurePoint": "redo",
        "expectedBehavior": "maintain_stack_consistency"
      }
    ]
  },

  "performanceConstraints": {
    "undoOperation": {
      "maxTime": 100,
      "unit": "milliseconds"
    },
    "redoOperation": {
      "maxTime": 100,
      "unit": "milliseconds"
    },
    "stackTraversal": {
      "maxTime": 50,
      "unit": "milliseconds",
      "maxSteps": 100
    },
    "memoryUsage": {
      "maxPerCommand": "1KB",
      "totalStackMax": "50KB"
    }
  }
}