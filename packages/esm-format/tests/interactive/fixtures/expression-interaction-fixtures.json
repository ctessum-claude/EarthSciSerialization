{
  "clickSelectionPaths": {
    "description": "Test cases for click-to-select behavior with path tracking",
    "cases": [
      {
        "name": "simple_number_selection",
        "expression": 42,
        "clickTarget": { "path": [], "type": "number" },
        "expectedSelection": { "path": [], "value": 42, "type": "number" },
        "expectedHighlight": "number-literal"
      },
      {
        "name": "variable_selection",
        "expression": "temperature",
        "clickTarget": { "path": [], "type": "variable" },
        "expectedSelection": { "path": [], "value": "temperature", "type": "variable" },
        "expectedHighlight": "variable-ref"
      },
      {
        "name": "nested_operator_selection",
        "expression": { "op": "+", "args": [1, { "op": "*", "args": ["x", "y"] }] },
        "clickTarget": { "path": [1], "type": "operator" },
        "expectedSelection": { "path": [1], "value": { "op": "*", "args": ["x", "y"] }, "type": "operator" },
        "expectedHighlight": "binary-operator"
      },
      {
        "name": "deep_nested_selection",
        "expression": { "op": "+", "args": [{ "op": "*", "args": ["a", { "op": "/", "args": ["b", "c"] }] }, "d"] },
        "clickTarget": { "path": [0, 1, 0], "type": "variable" },
        "expectedSelection": { "path": [0, 1, 0], "value": "b", "type": "variable" },
        "expectedHighlight": "variable-ref"
      },
      {
        "name": "function_call_selection",
        "expression": { "op": "sin", "args": [{ "op": "+", "args": ["x", "y"] }] },
        "clickTarget": { "path": [0, 1], "type": "variable" },
        "expectedSelection": { "path": [0, 1], "value": "y", "type": "variable" },
        "expectedHighlight": "variable-ref"
      }
    ]
  },

  "hoverHighlightEquivalenceClasses": {
    "description": "Test cases for highlighting equivalent variables and related elements on hover",
    "cases": [
      {
        "name": "single_variable_equivalence",
        "expression": { "op": "+", "args": ["temperature", "temperature"] },
        "hoverTarget": { "path": [0], "variable": "temperature" },
        "expectedHighlights": [
          { "path": [0], "type": "primary-highlight" },
          { "path": [1], "type": "equivalent-highlight" }
        ]
      },
      {
        "name": "multiple_variable_instances",
        "expression": { "op": "*", "args": [
          { "op": "+", "args": ["x", "y"] },
          { "op": "-", "args": ["x", 2] }
        ]},
        "hoverTarget": { "path": [0, 0], "variable": "x" },
        "expectedHighlights": [
          { "path": [0, 0], "type": "primary-highlight" },
          { "path": [1, 0], "type": "equivalent-highlight" }
        ]
      },
      {
        "name": "cross_system_variable_highlighting",
        "models": {
          "transport": { "variables": { "concentration": { "name": "concentration", "type": "state" } } },
          "chemistry": { "variables": { "concentration": { "name": "concentration", "type": "state" } } }
        },
        "expression": { "op": "+", "args": ["transport.concentration", "chemistry.concentration"] },
        "hoverTarget": { "path": [0], "variable": "concentration" },
        "expectedHighlights": [
          { "path": [0], "type": "primary-highlight", "scope": "transport" },
          { "path": [1], "type": "cross-system-highlight", "scope": "chemistry" }
        ]
      },
      {
        "name": "function_parameter_equivalence",
        "expression": { "op": "sin", "args": [{ "op": "*", "args": ["theta", { "op": "+", "args": ["theta", "pi"] }] }] },
        "hoverTarget": { "path": [0, 0], "variable": "theta" },
        "expectedHighlights": [
          { "path": [0, 0], "type": "primary-highlight" },
          { "path": [0, 1, 0], "type": "equivalent-highlight" }
        ]
      },
      {
        "name": "no_equivalence_case",
        "expression": { "op": "+", "args": ["x", "y"] },
        "hoverTarget": { "path": [0], "variable": "x" },
        "expectedHighlights": [
          { "path": [0], "type": "primary-highlight" }
        ]
      }
    ]
  },

  "dragDropReorderingCommutativeOps": {
    "description": "Test cases for drag-and-drop reordering of commutative operations",
    "cases": [
      {
        "name": "simple_addition_reorder",
        "initialExpression": { "op": "+", "args": ["a", "b"] },
        "dragSource": { "path": [0] },
        "dropTarget": { "path": [1] },
        "expectedResult": { "op": "+", "args": ["b", "a"] },
        "isValidReorder": true,
        "reason": "Addition is commutative"
      },
      {
        "name": "multiplication_reorder",
        "initialExpression": { "op": "*", "args": ["x", "y", "z"] },
        "dragSource": { "path": [2] },
        "dropTarget": { "path": [0] },
        "expectedResult": { "op": "*", "args": ["z", "x", "y"] },
        "isValidReorder": true,
        "reason": "Multiplication is commutative"
      },
      {
        "name": "invalid_subtraction_reorder",
        "initialExpression": { "op": "-", "args": ["a", "b"] },
        "dragSource": { "path": [0] },
        "dropTarget": { "path": [1] },
        "expectedResult": { "op": "-", "args": ["a", "b"] },
        "isValidReorder": false,
        "reason": "Subtraction is not commutative"
      },
      {
        "name": "invalid_division_reorder",
        "initialExpression": { "op": "/", "args": ["numerator", "denominator"] },
        "dragSource": { "path": [0] },
        "dropTarget": { "path": [1] },
        "expectedResult": { "op": "/", "args": ["numerator", "denominator"] },
        "isValidReorder": false,
        "reason": "Division is not commutative"
      },
      {
        "name": "nested_commutative_reorder",
        "initialExpression": { "op": "+", "args": [
          { "op": "*", "args": ["a", "b"] },
          { "op": "*", "args": ["c", "d"] }
        ]},
        "dragSource": { "path": [0, 1] },
        "dropTarget": { "path": [0, 0] },
        "expectedResult": { "op": "+", "args": [
          { "op": "*", "args": ["b", "a"] },
          { "op": "*", "args": ["c", "d"] }
        ]},
        "isValidReorder": true,
        "reason": "Inner multiplication is commutative"
      },
      {
        "name": "logical_and_reorder",
        "initialExpression": { "op": "and", "args": ["p", "q", "r"] },
        "dragSource": { "path": [1] },
        "dropTarget": { "path": [2] },
        "expectedResult": { "op": "and", "args": ["p", "r", "q"] },
        "isValidReorder": true,
        "reason": "Logical AND is commutative"
      }
    ]
  },

  "structuralEditingOperations": {
    "description": "Test cases for structural editing operations like wrap, unwrap, and delete",
    "cases": [
      {
        "name": "wrap_with_function",
        "operation": "wrap",
        "target": { "path": [0], "value": "x" },
        "wrapper": { "op": "sin", "args": ["PLACEHOLDER"] },
        "beforeExpression": { "op": "+", "args": ["x", "y"] },
        "afterExpression": { "op": "+", "args": [{ "op": "sin", "args": ["x"] }, "y"] }
      },
      {
        "name": "wrap_with_parentheses",
        "operation": "wrap",
        "target": { "path": [1], "value": { "op": "+", "args": ["a", "b"] } },
        "wrapper": { "op": "()", "args": ["PLACEHOLDER"] },
        "beforeExpression": { "op": "*", "args": ["x", { "op": "+", "args": ["a", "b"] }] },
        "afterExpression": { "op": "*", "args": ["x", { "op": "()", "args": [{ "op": "+", "args": ["a", "b"] }] }] }
      },
      {
        "name": "unwrap_function",
        "operation": "unwrap",
        "target": { "path": [0], "value": { "op": "sin", "args": ["theta"] } },
        "beforeExpression": { "op": "*", "args": [{ "op": "sin", "args": ["theta"] }, "amplitude"] },
        "afterExpression": { "op": "*", "args": ["theta", "amplitude"] }
      },
      {
        "name": "unwrap_parentheses",
        "operation": "unwrap",
        "target": { "path": [1], "value": { "op": "()", "args": [{ "op": "+", "args": ["a", "b"] }] } },
        "beforeExpression": { "op": "*", "args": ["x", { "op": "()", "args": [{ "op": "+", "args": ["a", "b"] }] }] },
        "afterExpression": { "op": "*", "args": ["x", { "op": "+", "args": ["a", "b"] }] }
      },
      {
        "name": "delete_term",
        "operation": "delete",
        "target": { "path": [1], "value": "b" },
        "beforeExpression": { "op": "+", "args": ["a", "b", "c"] },
        "afterExpression": { "op": "+", "args": ["a", "c"] }
      },
      {
        "name": "delete_binary_operation",
        "operation": "delete",
        "target": { "path": [], "value": { "op": "+", "args": ["x", "y"] } },
        "beforeExpression": { "op": "+", "args": ["x", "y"] },
        "afterExpression": "x",
        "deleteStrategy": "keep_first_operand"
      },
      {
        "name": "delete_function_call",
        "operation": "delete",
        "target": { "path": [0], "value": { "op": "cos", "args": ["t"] } },
        "beforeExpression": { "op": "*", "args": [{ "op": "cos", "args": ["t"] }, "amplitude"] },
        "afterExpression": { "op": "*", "args": ["t", "amplitude"] },
        "deleteStrategy": "unwrap_before_delete"
      }
    ]
  },

  "inlineEditingScenarios": {
    "description": "Test cases for double-click editing of numbers and variables",
    "cases": [
      {
        "name": "edit_simple_number",
        "target": { "path": [], "value": 42, "type": "number" },
        "editAction": "double_click",
        "initialValue": "42",
        "editedValue": "3.14159",
        "expectedResult": 3.14159,
        "validation": { "type": "number", "valid": true }
      },
      {
        "name": "edit_scientific_notation",
        "target": { "path": [0], "value": 1000000, "type": "number" },
        "editAction": "double_click",
        "initialValue": "1000000",
        "editedValue": "1.5e6",
        "expectedResult": 1500000,
        "validation": { "type": "scientific", "valid": true }
      },
      {
        "name": "edit_variable_name",
        "target": { "path": [1], "value": "temp", "type": "variable" },
        "editAction": "double_click",
        "initialValue": "temp",
        "editedValue": "temperature",
        "expectedResult": "temperature",
        "validation": { "type": "identifier", "valid": true }
      },
      {
        "name": "invalid_number_edit",
        "target": { "path": [], "value": 10, "type": "number" },
        "editAction": "double_click",
        "initialValue": "10",
        "editedValue": "not_a_number",
        "expectedResult": 10,
        "validation": { "type": "number", "valid": false, "error": "Invalid number format" }
      },
      {
        "name": "invalid_variable_name",
        "target": { "path": [], "value": "x", "type": "variable" },
        "editAction": "double_click",
        "initialValue": "x",
        "editedValue": "123invalid",
        "expectedResult": "x",
        "validation": { "type": "identifier", "valid": false, "error": "Variable names cannot start with numbers" }
      },
      {
        "name": "edit_nested_number",
        "expression": { "op": "+", "args": [{ "op": "*", "args": [2, "x"] }, 5] },
        "target": { "path": [0, 0], "value": 2, "type": "number" },
        "editAction": "double_click",
        "initialValue": "2",
        "editedValue": "3.5",
        "expectedResult": { "op": "+", "args": [{ "op": "*", "args": [3.5, "x"] }, 5] }
      },
      {
        "name": "edit_function_argument",
        "expression": { "op": "sin", "args": [{ "op": "*", "args": ["pi", "frequency"] }] },
        "target": { "path": [0, 1], "value": "frequency", "type": "variable" },
        "editAction": "double_click",
        "initialValue": "frequency",
        "editedValue": "freq",
        "expectedResult": { "op": "sin", "args": [{ "op": "*", "args": ["pi", "freq"] }] }
      },
      {
        "name": "escape_cancels_edit",
        "target": { "path": [], "value": 42, "type": "number" },
        "editAction": "double_click",
        "initialValue": "42",
        "editedValue": "999",
        "keyPress": "Escape",
        "expectedResult": 42,
        "editCanceled": true
      }
    ]
  },

  "undoRedoStateTransitions": {
    "description": "Test cases for undo/redo functionality with state transitions",
    "cases": [
      {
        "name": "simple_edit_undo_redo",
        "initialState": 42,
        "operations": [
          {
            "type": "edit",
            "target": { "path": [] },
            "oldValue": 42,
            "newValue": 100,
            "commandId": "edit-1"
          }
        ],
        "stateHistory": [
          { "state": 42, "commandId": null },
          { "state": 100, "commandId": "edit-1" }
        ],
        "undoSteps": [
          { "undoCommand": "edit-1", "resultState": 42 }
        ],
        "redoSteps": [
          { "redoCommand": "edit-1", "resultState": 100 }
        ]
      },
      {
        "name": "multiple_operations_undo_redo",
        "initialState": { "op": "+", "args": ["x", "y"] },
        "operations": [
          {
            "type": "edit",
            "target": { "path": [0] },
            "oldValue": "x",
            "newValue": "a",
            "commandId": "edit-1"
          },
          {
            "type": "edit",
            "target": { "path": [1] },
            "oldValue": "y",
            "newValue": "b",
            "commandId": "edit-2"
          },
          {
            "type": "wrap",
            "target": { "path": [0] },
            "wrapper": { "op": "sin", "args": ["PLACEHOLDER"] },
            "commandId": "wrap-1"
          }
        ],
        "stateHistory": [
          { "state": { "op": "+", "args": ["x", "y"] }, "commandId": null },
          { "state": { "op": "+", "args": ["a", "y"] }, "commandId": "edit-1" },
          { "state": { "op": "+", "args": ["a", "b"] }, "commandId": "edit-2" },
          { "state": { "op": "+", "args": [{ "op": "sin", "args": ["a"] }, "b"] }, "commandId": "wrap-1" }
        ],
        "undoSteps": [
          { "undoCommand": "wrap-1", "resultState": { "op": "+", "args": ["a", "b"] } },
          { "undoCommand": "edit-2", "resultState": { "op": "+", "args": ["a", "y"] } },
          { "undoCommand": "edit-1", "resultState": { "op": "+", "args": ["x", "y"] } }
        ]
      },
      {
        "name": "command_merging_consecutive_edits",
        "initialState": "hello",
        "operations": [
          { "type": "type", "char": "w", "commandId": "type-1", "timestamp": 1000 },
          { "type": "type", "char": "o", "commandId": "type-2", "timestamp": 1050 },
          { "type": "type", "char": "r", "commandId": "type-3", "timestamp": 1100 },
          { "type": "type", "char": "l", "commandId": "type-4", "timestamp": 1150 },
          { "type": "type", "char": "d", "commandId": "type-5", "timestamp": 1200 }
        ],
        "commandMerging": {
          "enabled": true,
          "threshold": 500,
          "mergedCommandId": "type-sequence-1"
        },
        "stateHistory": [
          { "state": "hello", "commandId": null },
          { "state": "helloworld", "commandId": "type-sequence-1" }
        ],
        "undoSteps": [
          { "undoCommand": "type-sequence-1", "resultState": "hello" }
        ]
      },
      {
        "name": "structural_operation_no_merge",
        "initialState": { "op": "+", "args": ["x", "y"] },
        "operations": [
          {
            "type": "delete",
            "target": { "path": [1] },
            "commandId": "delete-1",
            "timestamp": 2000
          },
          {
            "type": "edit",
            "target": { "path": [0] },
            "oldValue": "x",
            "newValue": "z",
            "commandId": "edit-1",
            "timestamp": 2010
          }
        ],
        "commandMerging": {
          "enabled": true,
          "structuralOperationsNoMerge": true
        },
        "stateHistory": [
          { "state": { "op": "+", "args": ["x", "y"] }, "commandId": null },
          { "state": "x", "commandId": "delete-1" },
          { "state": "z", "commandId": "edit-1" }
        ],
        "undoSteps": [
          { "undoCommand": "edit-1", "resultState": "x" },
          { "undoCommand": "delete-1", "resultState": { "op": "+", "args": ["x", "y"] } }
        ]
      },
      {
        "name": "undo_stack_size_limit",
        "initialState": 0,
        "stackSizeLimit": 3,
        "operations": [
          { "type": "edit", "newValue": 1, "commandId": "edit-1" },
          { "type": "edit", "newValue": 2, "commandId": "edit-2" },
          { "type": "edit", "newValue": 3, "commandId": "edit-3" },
          { "type": "edit", "newValue": 4, "commandId": "edit-4" },
          { "type": "edit", "newValue": 5, "commandId": "edit-5" }
        ],
        "finalUndoStack": [
          { "commandId": "edit-5", "state": 4 },
          { "commandId": "edit-4", "state": 3 },
          { "commandId": "edit-3", "state": 2 }
        ],
        "availableUndoSteps": 3,
        "oldestStateAccessible": 2
      },
      {
        "name": "branch_after_undo",
        "initialState": { "op": "+", "args": ["a", "b"] },
        "operations": [
          { "type": "edit", "target": { "path": [0] }, "newValue": "x", "commandId": "edit-1" },
          { "type": "edit", "target": { "path": [1] }, "newValue": "y", "commandId": "edit-2" }
        ],
        "undoOperations": [
          { "undoCommand": "edit-2" }
        ],
        "newOperations": [
          { "type": "edit", "target": { "path": [1] }, "newValue": "z", "commandId": "edit-3" }
        ],
        "finalState": { "op": "+", "args": ["x", "z"] },
        "redoStackCleared": true,
        "lostCommands": ["edit-2"]
      }
    ]
  },

  "complexNestedExpressions": {
    "description": "Test cases for complex nested expressions with multiple interaction types",
    "cases": [
      {
        "name": "atmospheric_chemistry_expression",
        "expression": {
          "op": "*",
          "args": [
            { "op": "exp", "args": [{ "op": "/", "args": [{ "op": "-", "args": ["Ea"] }, { "op": "*", "args": ["R", "T"] }] }] },
            { "op": "*", "args": ["A", { "op": "^", "args": [{ "op": "*", "args": ["O3", "NO"] }, 0.5] }] }
          ]
        },
        "interactionTests": [
          {
            "type": "hover",
            "target": { "path": [0, 0, 1, 1], "variable": "T" },
            "expectedHighlights": [{ "path": [0, 0, 1, 1], "type": "primary-highlight" }]
          },
          {
            "type": "edit",
            "target": { "path": [1, 1, 1], "value": 0.5 },
            "newValue": 0.75,
            "expectedPath": [1, 1, 1]
          },
          {
            "type": "drag_reorder",
            "source": { "path": [1, 1, 0, 0] },
            "target": { "path": [1, 1, 0, 1] },
            "isValid": true,
            "reason": "Multiplication is commutative"
          }
        ]
      },
      {
        "name": "differential_equation_expression",
        "expression": {
          "op": "D",
          "args": [
            { "op": "+", "args": [
              { "op": "*", "args": [{ "op": "-", "args": ["k1"] }, "C"] },
              { "op": "*", "args": ["k2", { "op": "*", "args": ["A", "B"] }] }
            ]}
          ],
          "wrt": "t"
        },
        "interactionTests": [
          {
            "type": "wrap",
            "target": { "path": [0, 1] },
            "wrapper": { "op": "()", "args": ["PLACEHOLDER"] },
            "expectedResult": {
              "op": "D",
              "args": [
                { "op": "+", "args": [
                  { "op": "*", "args": [{ "op": "-", "args": ["k1"] }, "C"] },
                  { "op": "()", "args": [{ "op": "*", "args": ["k2", { "op": "*", "args": ["A", "B"] }] }] }
                ]}
              ],
              "wrt": "t"
            }
          },
          {
            "type": "hover",
            "target": { "path": [0, 1, 1, 0], "variable": "A" },
            "expectedHighlights": [{ "path": [0, 1, 1, 0], "type": "primary-highlight" }]
          }
        ]
      }
    ]
  },

  "performanceBenchmarks": {
    "description": "Performance benchmarks for interactive operations",
    "targets": {
      "clickResponse": 50,
      "hoverHighlight": 100,
      "dragFeedback": 16,
      "editModeEntry": 200,
      "undoRedo": 100,
      "complexExpressionRender": 300
    },
    "stressTests": [
      {
        "name": "rapid_clicks",
        "description": "Measure response to rapid clicking",
        "operations": 50,
        "timeLimit": 5000,
        "expectedAverageResponse": 50
      },
      {
        "name": "deep_nesting_interaction",
        "description": "Test interaction with deeply nested expressions",
        "nestingDepth": 20,
        "interactionTypes": ["click", "hover", "edit"],
        "maxResponseTime": 500
      },
      {
        "name": "many_variables_highlight",
        "description": "Test highlighting with many equivalent variables",
        "variableInstances": 100,
        "hoverResponseTime": 200,
        "memoryLimit": "5MB"
      }
    ]
  }
}