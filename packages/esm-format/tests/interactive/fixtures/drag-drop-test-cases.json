{
  "dragDropMechanics": {
    "description": "Core drag-and-drop interaction mechanics and validation",
    "validationRules": {
      "commutativeOperations": ["add", "multiply", "and", "or", "xor", "min", "max"],
      "nonCommutativeOperations": ["subtract", "divide", "power", "modulo", "implies"],
      "structuralConstraints": {
        "functionArguments": "can_reorder_within_same_function",
        "differentTypes": "cannot_swap_number_with_operator",
        "parentheses": "respect_grouping_boundaries"
      }
    },
    "visualFeedback": {
      "dragStart": {
        "sourceElement": "add_dragging_class",
        "ghostElement": "create_semi_transparent_copy",
        "cursor": "grabbing"
      },
      "dragOver": {
        "validDropZone": "highlight_green",
        "invalidDropZone": "highlight_red",
        "insertionPoint": "show_drop_indicator"
      },
      "dragEnd": {
        "successful": "animate_to_position",
        "failed": "animate_back_to_origin"
      }
    }
  },

  "commutativeReorderingCases": {
    "simple": [
      {
        "name": "two_term_addition",
        "expression": { "op": "+", "args": ["a", "b"] },
        "dragSource": { "path": [0], "element": "a" },
        "dropTarget": { "path": [1], "position": "before" },
        "expectedResult": { "op": "+", "args": ["b", "a"] },
        "isValid": true
      },
      {
        "name": "three_term_multiplication",
        "expression": { "op": "*", "args": ["x", "y", "z"] },
        "dragSource": { "path": [2], "element": "z" },
        "dropTarget": { "path": [0], "position": "before" },
        "expectedResult": { "op": "*", "args": ["z", "x", "y"] },
        "isValid": true
      },
      {
        "name": "logical_and_reorder",
        "expression": { "op": "and", "args": ["p", "q", "r"] },
        "dragSource": { "path": [1], "element": "q" },
        "dropTarget": { "path": [2], "position": "after" },
        "expectedResult": { "op": "and", "args": ["p", "r", "q"] },
        "isValid": true
      }
    ],

    "complex": [
      {
        "name": "nested_commutative_operations",
        "expression": {
          "op": "+",
          "args": [
            { "op": "*", "args": ["a", "b"] },
            { "op": "*", "args": ["c", "d"] },
            "e"
          ]
        },
        "dragSource": { "path": [0, 1], "element": "b" },
        "dropTarget": { "path": [0, 0], "position": "before" },
        "expectedResult": {
          "op": "+",
          "args": [
            { "op": "*", "args": ["b", "a"] },
            { "op": "*", "args": ["c", "d"] },
            "e"
          ]
        },
        "isValid": true,
        "description": "Reordering within nested multiplication"
      },
      {
        "name": "cross_level_addition_reorder",
        "expression": {
          "op": "+",
          "args": [
            { "op": "*", "args": ["a", "b"] },
            "c"
          ]
        },
        "dragSource": { "path": [1], "element": "c" },
        "dropTarget": { "path": [0], "position": "before" },
        "expectedResult": {
          "op": "+",
          "args": [
            "c",
            { "op": "*", "args": ["a", "b"] }
          ]
        },
        "isValid": true,
        "description": "Reordering terms at top level"
      }
    ]
  },

  "nonCommutativeValidation": {
    "invalidCases": [
      {
        "name": "subtraction_reorder_blocked",
        "expression": { "op": "-", "args": ["a", "b"] },
        "dragSource": { "path": [0], "element": "a" },
        "dropTarget": { "path": [1], "position": "after" },
        "expectedResult": { "op": "-", "args": ["a", "b"] },
        "isValid": false,
        "errorMessage": "Cannot reorder terms in subtraction - operation is not commutative",
        "visualFeedback": "red_highlight_on_drop_zone"
      },
      {
        "name": "division_reorder_blocked",
        "expression": { "op": "/", "args": ["numerator", "denominator"] },
        "dragSource": { "path": [1], "element": "denominator" },
        "dropTarget": { "path": [0], "position": "before" },
        "expectedResult": { "op": "/", "args": ["numerator", "denominator"] },
        "isValid": false,
        "errorMessage": "Cannot swap numerator and denominator in division"
      },
      {
        "name": "power_reorder_blocked",
        "expression": { "op": "^", "args": ["base", "exponent"] },
        "dragSource": { "path": [0], "element": "base" },
        "dropTarget": { "path": [1], "position": "after" },
        "expectedResult": { "op": "^", "args": ["base", "exponent"] },
        "isValid": false,
        "errorMessage": "Cannot reorder base and exponent in power operation"
      }
    ],

    "borderlineCases": [
      {
        "name": "matrix_multiplication",
        "expression": { "op": "matmul", "args": ["A", "B"] },
        "dragSource": { "path": [0], "element": "A" },
        "dropTarget": { "path": [1], "position": "after" },
        "isValid": false,
        "reason": "Matrix multiplication is not commutative",
        "configurable": true,
        "note": "Some contexts might allow reordering with transpose"
      },
      {
        "name": "function_composition",
        "expression": { "op": "compose", "args": ["f", "g"] },
        "dragSource": { "path": [0], "element": "f" },
        "dropTarget": { "path": [1], "position": "after" },
        "isValid": false,
        "reason": "Function composition is not commutative: f(g(x)) ≠ g(f(x))"
      }
    ]
  },

  "structuralConstraints": {
    "crossTypeValidation": [
      {
        "name": "number_operator_swap_blocked",
        "expression": { "op": "+", "args": [42, { "op": "*", "args": ["x", "y"] }] },
        "dragSource": { "path": [0], "element": 42, "type": "number" },
        "dropTarget": { "path": [1], "element": { "op": "*", "args": ["x", "y"] }, "type": "operator" },
        "isValid": false,
        "errorMessage": "Cannot replace operator with number",
        "structuralIssue": "type_mismatch"
      },
      {
        "name": "variable_function_swap_allowed",
        "expression": { "op": "+", "args": ["x", { "op": "sin", "args": ["y"] }] },
        "dragSource": { "path": [0], "element": "x", "type": "variable" },
        "dropTarget": { "path": [1], "element": { "op": "sin", "args": ["y"] }, "type": "function" },
        "isValid": true,
        "description": "Both are expressions, structurally compatible"
      }
    ],

    "parenthesesRespect": [
      {
        "name": "drag_into_parentheses",
        "expression": { "op": "+", "args": [{ "op": "()", "args": [{ "op": "*", "args": ["a", "b"] }] }, "c"] },
        "dragSource": { "path": [1], "element": "c" },
        "dropTarget": { "path": [0, 0, 1], "position": "after" },
        "expectedResult": { "op": "+", "args": [{ "op": "()", "args": [{ "op": "*", "args": ["a", "b", "c"] }] }] },
        "isValid": true,
        "description": "Dragging term into parenthesized multiplication"
      },
      {
        "name": "drag_out_of_parentheses",
        "expression": { "op": "+", "args": [{ "op": "()", "args": [{ "op": "+", "args": ["a", "b"] }] }, "c"] },
        "dragSource": { "path": [0, 0, 1], "element": "b" },
        "dropTarget": { "path": [1], "position": "after" },
        "expectedResult": { "op": "+", "args": [{ "op": "()", "args": ["a"] }, "c", "b"] },
        "isValid": true,
        "description": "Dragging term out of parentheses"
      }
    ],

    "functionArgumentReorder": [
      {
        "name": "single_argument_function_no_reorder",
        "expression": { "op": "sin", "args": ["x"] },
        "dragSource": { "path": [0], "element": "x" },
        "dropTarget": { "path": [], "position": "outside" },
        "isValid": false,
        "errorMessage": "Single argument functions cannot reorder arguments internally"
      },
      {
        "name": "multi_argument_function_reorder",
        "expression": { "op": "atan2", "args": ["y", "x"] },
        "dragSource": { "path": [0], "element": "y" },
        "dropTarget": { "path": [1], "position": "after" },
        "expectedResult": { "op": "atan2", "args": ["x", "y"] },
        "isValid": true,
        "warning": "Reordering atan2 arguments changes mathematical meaning",
        "confirmationRequired": true
      }
    ]
  },

  "touchAndMobileSupport": {
    "touchInteractions": [
      {
        "name": "touch_drag_with_haptic",
        "gesture": "long_press_and_drag",
        "hapticFeedback": {
          "onDragStart": "light_impact",
          "onValidDropZone": "selection_feedback",
          "onInvalidDropZone": "error_feedback",
          "onDrop": "heavy_impact"
        },
        "visualAdaptations": {
          "largerDropZones": "increase_touch_targets",
          "ghostElementSize": "125%_of_original",
          "scrollBehavior": "auto_scroll_when_near_edges"
        }
      },
      {
        "name": "multi_touch_gestures",
        "gesture": "two_finger_tap",
        "action": "select_entire_subexpression",
        "followupGesture": "drag_with_one_finger",
        "expectedBehavior": "drag_selected_subexpression"
      }
    ],

    "accessibilityAlternatives": [
      {
        "name": "keyboard_reorder",
        "keySequence": ["Tab", "Space", "ArrowRight", "Space"],
        "description": "Tab to element, Space to pick up, arrows to move, Space to drop",
        "announcements": [
          "Element selected for moving",
          "Moving to position 2 of 3",
          "Element placed at new position"
        ]
      },
      {
        "name": "context_menu_reorder",
        "trigger": "right_click_or_long_press",
        "menu": [
          "Move Left",
          "Move Right",
          "Move to Beginning",
          "Move to End"
        ],
        "keyboardShortcuts": {
          "moveLeft": "Ctrl+Shift+Left",
          "moveRight": "Ctrl+Shift+Right"
        }
      }
    ]
  },

  "performanceConstraints": {
    "dragFeedback": {
      "maxResponseTime": 16,
      "unit": "milliseconds",
      "targetFrameRate": 60
    },
    "validationTime": {
      "maxResponseTime": 50,
      "unit": "milliseconds",
      "description": "Time to validate drop zone"
    },
    "animationDuration": {
      "snapBack": 300,
      "successful": 200,
      "failed": 400,
      "unit": "milliseconds"
    },
    "memoryUsage": {
      "ghostElementOverhead": "minimal",
      "dropZoneCalculation": "cache_when_possible"
    }
  },

  "edgeCases": [
    {
      "name": "drag_to_self",
      "expression": { "op": "+", "args": ["a", "b"] },
      "dragSource": { "path": [0] },
      "dropTarget": { "path": [0] },
      "expectedBehavior": "no_operation",
      "visualFeedback": "return_to_original_position"
    },
    {
      "name": "drag_during_edit_mode",
      "expression": "temperature",
      "initialState": "editing_in_progress",
      "dragAttempt": true,
      "expectedBehavior": "cancel_edit_then_allow_drag",
      "alternativeBehavior": "block_drag_during_edit"
    },
    {
      "name": "drag_very_large_expression",
      "expression": "generate_deeply_nested_50_levels",
      "performanceConstraints": {
        "maxRenderTime": 100,
        "maxMemoryOverhead": "5MB"
      },
      "fallbackBehavior": "show_simplified_ghost_element"
    },
    {
      "name": "rapid_drag_operations",
      "sequence": [
        { "drag": "element_a", "to": "position_1", "timing": 0 },
        { "drag": "element_b", "to": "position_2", "timing": 50 },
        { "drag": "element_a", "to": "position_3", "timing": 100 }
      ],
      "expectedBehavior": "queue_operations_or_cancel_conflicting",
      "maxConcurrentDrags": 1
    }
  ]
}