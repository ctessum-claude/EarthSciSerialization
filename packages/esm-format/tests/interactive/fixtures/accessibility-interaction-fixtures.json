{
  "keyboardNavigation": {
    "description": "Comprehensive keyboard navigation patterns for expression editing",
    "navigationModes": {
      "structural": {
        "description": "Navigate based on expression structure",
        "keys": {
          "Tab": "next_focusable_element",
          "Shift+Tab": "previous_focusable_element",
          "ArrowRight": "next_sibling_or_first_child",
          "ArrowLeft": "previous_sibling_or_parent",
          "ArrowDown": "first_child_or_next_uncle",
          "ArrowUp": "parent_or_previous_uncle",
          "Home": "first_element_in_expression",
          "End": "last_element_in_expression"
        }
      },
      "linear": {
        "description": "Navigate in reading order (left-to-right, top-to-bottom)",
        "keys": {
          "ArrowRight": "next_element_in_reading_order",
          "ArrowLeft": "previous_element_in_reading_order",
          "Ctrl+ArrowRight": "next_word_boundary",
          "Ctrl+ArrowLeft": "previous_word_boundary"
        }
      }
    },
    "testCases": [
      {
        "name": "simple_binary_expression_navigation",
        "expression": { "op": "+", "args": ["a", "b"] },
        "navigationSequence": [
          { "key": "Tab", "expectedFocus": { "path": [0], "element": "a" } },
          { "key": "ArrowRight", "expectedFocus": { "path": [], "element": "+" } },
          { "key": "ArrowRight", "expectedFocus": { "path": [1], "element": "b" } },
          { "key": "ArrowLeft", "expectedFocus": { "path": [], "element": "+" } },
          { "key": "ArrowLeft", "expectedFocus": { "path": [0], "element": "a" } }
        ]
      },
      {
        "name": "nested_expression_navigation",
        "expression": { "op": "*", "args": [{ "op": "+", "args": ["x", "y"] }, "z"] },
        "navigationSequence": [
          { "key": "Tab", "expectedFocus": { "path": [0, 0], "element": "x" } },
          { "key": "ArrowDown", "expectedFocus": { "path": [0], "element": "+" } },
          { "key": "ArrowRight", "expectedFocus": { "path": [0, 1], "element": "y" } },
          { "key": "ArrowUp", "expectedFocus": { "path": [], "element": "*" } },
          { "key": "ArrowRight", "expectedFocus": { "path": [1], "element": "z" } }
        ]
      },
      {
        "name": "function_call_navigation",
        "expression": { "op": "sin", "args": [{ "op": "*", "args": ["pi", "x"] }] },
        "navigationSequence": [
          { "key": "Tab", "expectedFocus": { "path": [], "element": "sin" } },
          { "key": "ArrowDown", "expectedFocus": { "path": [0, 0], "element": "pi" } },
          { "key": "ArrowRight", "expectedFocus": { "path": [0], "element": "*" } },
          { "key": "ArrowRight", "expectedFocus": { "path": [0, 1], "element": "x" } }
        ]
      }
    ]
  },

  "screenReaderSupport": {
    "description": "ARIA labels, live regions, and announcements for screen readers",
    "ariaLabels": {
      "expressionTypes": {
        "number": "Number: {value}",
        "variable": "Variable: {name}",
        "binaryOperator": "{operator} operator with {argCount} operands",
        "function": "Function {name} with {argCount} arguments",
        "parentheses": "Grouped expression"
      },
      "interactionStates": {
        "selected": "Selected",
        "editing": "Editing",
        "invalid": "Invalid value",
        "highlighted": "Highlighted equivalent"
      }
    },
    "liveRegions": [
      {
        "id": "expression-status",
        "aria-live": "polite",
        "purpose": "Announce changes to expression structure",
        "examples": [
          "Added sine function around variable x",
          "Removed term b from addition",
          "Changed variable name from temp to temperature"
        ]
      },
      {
        "id": "validation-feedback",
        "aria-live": "assertive",
        "purpose": "Announce validation errors immediately",
        "examples": [
          "Error: Invalid variable name",
          "Error: Division by zero",
          "Warning: Undefined variable reference"
        ]
      },
      {
        "id": "interaction-feedback",
        "aria-live": "polite",
        "purpose": "Announce interaction results",
        "examples": [
          "Moved variable x to position 2",
          "Entered edit mode for number 42",
          "Canceled edit operation"
        ]
      }
    ],
    "testCases": [
      {
        "name": "expression_reading",
        "expression": { "op": "+", "args": [42, "temperature"] },
        "expectedAnnouncement": "Addition with 2 operands: Number 42, plus, Variable temperature",
        "readingOrder": "depth-first with operator context"
      },
      {
        "name": "edit_mode_announcement",
        "action": "double_click_number",
        "target": { "path": [0], "value": 42 },
        "expectedAnnouncement": "Editing number 42. Current value: 42",
        "followupKeystrokes": "123",
        "expectedLiveAnnouncement": "Value changed to 123"
      },
      {
        "name": "structural_change_announcement",
        "action": "wrap_with_function",
        "target": { "path": [1], "value": "x" },
        "wrapper": { "op": "sin", "args": ["PLACEHOLDER"] },
        "expectedAnnouncement": "Wrapped variable x with sine function"
      }
    ]
  },

  "highContrastAndLowVision": {
    "description": "Visual accessibility for users with low vision or color blindness",
    "colorIndependentIndicators": {
      "selected": {
        "visual": "thick_border_plus_background",
        "pattern": "diagonal_stripes_or_dots",
        "animation": "subtle_pulse"
      },
      "highlighted": {
        "visual": "dashed_border",
        "pattern": "crosshatch",
        "animation": "none"
      },
      "error": {
        "visual": "red_background_with_icon",
        "pattern": "error_icon_plus_text",
        "animation": "shake_once"
      },
      "dragTarget": {
        "visual": "thick_green_border_with_arrow",
        "pattern": "directional_arrows",
        "animation": "border_flow"
      }
    },
    "contrastRequirements": {
      "wcag_aa": {
        "normalText": 4.5,
        "largeText": 3.0,
        "nonTextElements": 3.0
      },
      "wcag_aaa": {
        "normalText": 7.0,
        "largeText": 4.5,
        "nonTextElements": 4.5
      }
    },
    "testCases": [
      {
        "name": "high_contrast_selection",
        "backgroundColor": "#000000",
        "foregroundColor": "#FFFFFF",
        "selectedElementStyle": {
          "backgroundColor": "#FFFF00",
          "foregroundColor": "#000000",
          "border": "3px solid #FFFFFF"
        },
        "contrastRatio": 21.0
      },
      {
        "name": "color_blind_friendly_highlighting",
        "simulateColorBlindness": "deuteranopia",
        "originalColors": {
          "normal": "#333333",
          "selected": "#0066CC",
          "highlighted": "#FF6600",
          "error": "#CC0000"
        },
        "alternativeIndicators": {
          "selected": "solid_thick_border",
          "highlighted": "dashed_border",
          "error": "dotted_border_with_icon"
        }
      }
    ]
  },

  "motorAccessibility": {
    "description": "Accommodations for users with motor disabilities",
    "alternativeInteractions": {
      "clickTarget": {
        "minimumSize": "44px",
        "spacing": "8px",
        "description": "WCAG minimum touch target size"
      },
      "dragAndDrop": {
        "keyboardAlternative": {
          "select": "Space",
          "move": "Arrow keys",
          "confirm": "Enter",
          "cancel": "Escape"
        },
        "assistiveMode": {
          "enabled": "via_settings_or_preference",
          "features": [
            "larger_drop_zones",
            "magnetic_snapping",
            "hover_delay_tolerance"
          ]
        }
      },
      "editMode": {
        "activation": {
          "doubleClick": "standard",
          "singleClick": "with_modifier_key",
          "keyboardOnly": "F2_or_Enter",
          "dwellTime": "hover_for_2_seconds"
        },
        "exitMethods": [
          "Enter_to_save",
          "Escape_to_cancel",
          "Tab_to_save_and_move",
          "click_outside_to_save"
        ]
      }
    },
    "testCases": [
      {
        "name": "keyboard_only_expression_editing",
        "noMouse": true,
        "taskSequence": [
          { "action": "navigate_to_number", "keys": ["Tab", "Tab"] },
          { "action": "enter_edit_mode", "keys": ["F2"] },
          { "action": "change_value", "keys": ["Ctrl+A", "1", "2", "3"] },
          { "action": "confirm_edit", "keys": ["Enter"] },
          { "action": "navigate_to_variable", "keys": ["Tab"] },
          { "action": "wrap_with_function", "keys": ["Ctrl+W", "s", "i", "n", "Enter"] }
        ],
        "expectedResult": { "op": "+", "args": [123, { "op": "sin", "args": ["x"] }] }
      },
      {
        "name": "switch_navigation",
        "inputMethod": "switch_scanning",
        "scanningOptions": {
          "autoAdvance": true,
          "scanInterval": 2000,
          "highlightSequence": "linear_left_to_right"
        },
        "activationMethods": {
          "select": "switch_1",
          "activate": "switch_2",
          "back": "switch_1_long_press"
        }
      }
    ]
  },

  "cognitiveAccessibility": {
    "description": "Support for users with cognitive disabilities",
    "clarityFeatures": {
      "helpText": {
        "contextSensitive": true,
        "examples": [
          {
            "element": "number",
            "help": "This is a number. Double-click to edit it."
          },
          {
            "element": "variable",
            "help": "This is a variable that represents an unknown value."
          },
          {
            "element": "operator",
            "help": "This operator combines the values on either side."
          }
        ]
      },
      "visualSimplification": {
        "reducedAnimations": "respect_prefers_reduced_motion",
        "clearLabeling": "always_show_element_types",
        "consistentLayout": "fixed_positions_for_common_elements"
      },
      "errorPrevention": {
        "confirmDestructiveActions": [
          "delete_large_subexpression",
          "clear_entire_expression",
          "replace_complex_with_simple"
        ],
        "undoAlwaysAvailable": true,
        "autoSave": {
          "frequency": "every_30_seconds",
          "maxHistory": 10
        }
      }
    },
    "testCases": [
      {
        "name": "progressive_disclosure",
        "complexExpression": {
          "op": "+",
          "args": [
            { "op": "*", "args": [{ "op": "sin", "args": ["x"] }, "amplitude"] },
            { "op": "*", "args": ["frequency", "t"] }
          ]
        },
        "simplificationLevels": [
          { "level": 1, "display": "sin(x) * amplitude + frequency * t" },
          { "level": 2, "display": "[Trig Function] * [Variable] + [Variable] * [Variable]" },
          { "level": 3, "display": "[Complex Expression]" }
        ],
        "userControl": "toggle_via_button_or_preference"
      },
      {
        "name": "step_by_step_guidance",
        "task": "create_quadratic_formula",
        "guidanceSteps": [
          { "step": 1, "instruction": "Click the '+' button to start adding terms" },
          { "step": 2, "instruction": "Type 'a' for the first variable" },
          { "step": 3, "instruction": "Click the '*' button to multiply" },
          { "step": 4, "instruction": "Add the power operator '^'" }
        ],
        "allowSkipping": true,
        "allowRepeating": true
      }
    ]
  },

  "internationalAccessibility": {
    "description": "Accessibility considerations for international users",
    "languageSupport": {
      "rightToLeft": {
        "languages": ["Arabic", "Hebrew"],
        "navigationReversals": {
          "ArrowRight": "moves_left_in_RTL",
          "ArrowLeft": "moves_right_in_RTL",
          "Home": "rightmost_element",
          "End": "leftmost_element"
        }
      },
      "mathematicalNotation": {
        "decimalSeparator": {
          "US": ".",
          "European": ",",
          "parsing": "accept_both_input_formats"
        },
        "functionNames": {
          "localized": true,
          "examples": {
            "sin": ["sin", "seno", "正弦"],
            "log": ["log", "ln", "ログ"],
            "sqrt": ["sqrt", "√", "racine"]
          }
        }
      }
    },
    "testCases": [
      {
        "name": "arabic_expression_navigation",
        "locale": "ar-SA",
        "expression": { "op": "+", "args": ["س", "ص"] },
        "navigationDirection": "right_to_left",
        "screenReaderAnnouncement": "جمع مع معاملين: متغير س، زائد، متغير ص"
      },
      {
        "name": "european_number_format",
        "locale": "de-DE",
        "numberInput": "3,14159",
        "expectedParsing": 3.14159,
        "displayFormat": "3,14159"
      }
    ]
  },

  "performanceAccessibility": {
    "description": "Performance requirements that affect accessibility",
    "responseTimeRequirements": {
      "focusIndicator": {
        "maxDelay": 50,
        "unit": "milliseconds",
        "reason": "Immediate feedback for navigation"
      },
      "screenReaderAnnouncement": {
        "maxDelay": 200,
        "unit": "milliseconds",
        "reason": "Timely feedback for actions"
      },
      "keyboardNavigation": {
        "maxDelay": 100,
        "unit": "milliseconds",
        "reason": "Responsive navigation experience"
      }
    },
    "memoryConstraints": {
      "ariaLabelCache": {
        "maxSize": "1MB",
        "evictionPolicy": "LRU"
      },
      "announcementHistory": {
        "maxEntries": 50,
        "purpose": "Allow users to review recent announcements"
      }
    }
  }
}