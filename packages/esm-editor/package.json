{
  "name": "esm-editor",
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive SolidJS editor for EarthSciML Serialization Format expressions",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "dev": "vite",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "vitest run tests/editor/",
    "test:e2e:watch": "vitest --watch tests/editor/",
    "test:all": "vitest run src/ && vitest run tests/editor/",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "earth-science",
    "scientific-modeling",
    "editor",
    "solidjs",
    "typescript",
    "interactive",
    "expressions",
    "mathematical-modeling"
  ],
  "author": "EarthSciML Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/user/EarthSciSerialization.git",
    "directory": "packages/esm-editor"
  },
  "bugs": {
    "url": "https://github.com/user/EarthSciSerialization/issues"
  },
  "homepage": "https://github.com/user/EarthSciSerialization#readme",
  "dependencies": {
    "solid-js": "^1.8.0",
    "d3-force": "^3.0.0"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0",
    "solid-element": "^1.9.1",
    "esm-format": "workspace:*"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/d3-force": "^3.0.0",
    "@types/node": "^20.0.0",
    "jsdom": "^22.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}