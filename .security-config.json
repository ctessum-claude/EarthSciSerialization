{
  "vulnerability_databases": [
    "https://osv.dev/",
    "https://github.com/advisories/",
    "https://cve.mitre.org/",
    "https://rustsec.org/",
    "https://www.npmjs.com/advisories"
  ],
  "allowed_licenses": [
    "MIT",
    "Apache-2.0",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "GPL-3.0",
    "GPL-3.0-or-later",
    "LGPL-3.0",
    "LGPL-3.0-or-later",
    "ISC",
    "CC0-1.0",
    "Unlicense"
  ],
  "security_policies": {
    "require_signature": true,
    "max_vulnerability_score": 7.0,
    "block_deprecated_packages": true,
    "require_license": true,
    "scan_dependencies": true,
    "check_file_permissions": true,
    "generate_integrity_hashes": true,
    "scan_for_secrets": true
  },
  "package_repos": {
    "julia": "https://juliahub.com",
    "npm": "https://registry.npmjs.org",
    "pypi": "https://pypi.org",
    "cargo": "https://crates.io"
  },
  "excluded_paths": [
    "*/node_modules/*",
    "*/venv/*",
    "*/.git/*",
    "*/target/*",
    "*/__pycache__/*",
    "*/Manifest.toml",
    "*/.DS_Store",
    "*/thumbs.db"
  ],
  "critical_vulnerability_keywords": [
    "remote code execution",
    "privilege escalation",
    "arbitrary file write",
    "directory traversal",
    "sql injection",
    "code injection",
    "buffer overflow",
    "use after free"
  ]
}